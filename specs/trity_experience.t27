# Trinity Experience — Tracking Learned Knowledge
#
# This spec defines the experience database for Trinity.
# Part of modular compiler architecture (Ring-Z100 - Agent Protocol).
#
# This is a **mandatory law level (L7)** for all agent operations.
# Every benchmark run MUST save experience records to this database.
#
# This provides:
# - Reproducible trace of all experiments
# - Linking between benchmark results and ring completion
# - Machine-readable format for analysis agents
#
# See: `specs/trity_agent_protocol.t27` for agent completion protocol
# See: `specs/rings.t27` for ring status tracking

module: trity_experience;

// Import shared types
import:
  - compiler/types from specs/compiler/types.tri
  - vm_core from specs/vm_core.ti
  - trity_compress from specs/trity_compress.ti
  - trity_bench_bench_types from specs/trity_bench_bench_types.ti

// =============================================================================
// Experience Record Format
// =============================================================================

/// Experience record (canonical format)
///
/// Stores a single benchmark/experiment result.
/// All fields are MANDATORY for L7 compliance.
type ExperienceRecord = struct {
  /// Unique experience ID (UUID)
  id: String,

  /// Agent who created this experience
  agent_id: String,

  /// Task/Ring/RFC being worked on
  task_id: String,

  /// Experience type (benchmark, training, failure, etc.)
  experience_type: ExperienceType,

  /// Metric being measured
  metric: BenchmarkMetric,

  /// Value achieved
  value: f64,

  /// Artifacts created (files, commits)
  artifacts: Vec<String>,

  /// Reproducible git commit hash
  commit_hash: String,

  /// Timestamp (RFC3339)
  timestamp: String,
}

/// Experience types (classification)
type ExperienceType = enum(u8) {
  /// Benchmark run (measured time/memory/BPB)
  Benchmark = 0,

  /// Model training run
  Training = 1,

  /// Code/spec change (with tests passing)
  CodeChange = 2,

  /// Failure/error recovery
  Failure = 3,
}

/// Benchmark metric type
type BenchmarkMetric = enum(u8) {
  /// Bits per character (BPB)
  Bpb = 0,

  /// Time (wall clock)
  TimeMs = 1,

  /// Memory usage (bytes)
  MemoryBytes = 2,

  /// Accuracy
  Accuracy = 3,

  /// Compression ratio
  CompressionRatio = 4,

  /// Artifact size (bytes)
  ArtifactSize = 5,
}

/// Benchmark metric value
type BenchmarkMetricValue = struct {
  /// Metric type
  kind: BenchmarkMetric,

  /// Metric name (e.g., "inference_ops_per_sec")
  name: String,

  /// Measured value (numeric)
  value: f64,

  /// Unit symbol (e.g., "ms", "ops/s")
  unit: Option<String>,
}

