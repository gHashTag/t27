// =============================================================================
// Export Requirements
// =============================================================================

/// All Trinity agents MUST implement:
///
/// 1. **Experience Recording** — Every benchmark/experience MUST save to this format
/// 2. **Machine Readable** — Format must be parseable by analysis agents
/// 3. **Reproducible** — All artifacts must have git commit hash
/// 4. **Linked** — Records must link to tasks/rings/issues
///
/// See: `specs/trity_agent_protocol.t27` for agent completion protocol
/// See: `specs/rings.t27` for ring status tracking

export ExperienceRecord, ExperienceType, BenchmarkMetric, BenchmarkMetricValue;

/// Export experience query functions
export get_experience_by_task;
export get_experience_by_agent;
export get_benchmarks_by_metric;
export get_experience_by_ring;

