    // source_upload_text(client: NotebookLMClient, notebook_id: str, title: str, content: str) -> (Source, ErrorCode)
    // Upload text content as a source
    fn source_upload_text(client: NotebookLMClient, notebook_id: str, title: str, content: str) -> (Source, ErrorCode) {
