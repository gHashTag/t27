    enum ErrorCode {
        Success = 0,
        AuthenticationFailed = 1,
        NetworkError = 2,
        Timeout = 3,
        InvalidInput = 4,
        SourceNotFound = 5,
        NotebookNotFound = 6,
        RateLimited = 7,
        StorageError = 8,
        ConfigurationError = 9,
        UnknownError = 99,
    }

    // 272273274275276277278279280281282283284285286287288289290291292293294295296297298299300301302303304305306307308309310311312313314315316317318319320321322323324325326327328329330331332333334335336337338339
