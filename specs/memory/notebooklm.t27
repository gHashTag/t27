    const VERSION : u32 = 1;
    const DEFAULT_TIMEOUT_MS : u32 = 30000;
    const MAX_SOURCE_SIZE : u32 = 10485760; // 10MB
    const DEFAULT_NOTEBOOK_NAME : str = "t27-QUEEN-BRAIN";

    const AUTH_STATE_UNAUTHENTICATED : u8 = 0;
    const AUTH_STATE_AUTHENTICATED : u8 = 1;
    const AUTH_STATE_EXPIRED : u8 = 2;
    const AUTH_STATE_REFRESHING : u8 = 3;

    const CONNECTION_STATUS_DISCONNECTED : u8 = 0;
    const CONNECTION_STATUS_CONNECTING : u8 = 1;
    const CONNECTION_STATUS_CONNECTED : u8 = 2;
    const CONNECTION_STATUS_ERROR : u8 = 3;

    // 136137138139140141142143144145146147148149150151152153154155156157158159160161162163164165166167168169170171172173174175176177178179180181182183184185186187188189190191192193194195196197198199200201202203
