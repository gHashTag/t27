        updated_at: u64,
        source_count: usize,
    }

    struct Source {
        id: str,
        notebook_id: str,
        title: str,
        source_type: str, // "text", "url", "file", "youtube"
        status: str, // "processing", "ready", "error"
        created_at: u64,
    }

    // 680681682683684685686687688689690691692693694695696697698699700701702703704705706707708709710711712713714715716717718719720721722723724725726727728729730731732733734735736737738739740741742743744745746747
