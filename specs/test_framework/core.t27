test {
    let suite_results = run_test_suite();
    
    // Check that all tests pass
    let failed_count = suite_results.iter().filter(|r| r.verdict == Verdict::FAIL).count();
    assert!(failed_count == 0, "Test suite had {} failures", failed_count);
    
    // Generate TAP output
    let tap_reporter = TapReporter::new(suite_results.clone());
    let tap_output = tap_reporter.generate_tap();
    println!("TAP Output:\n{}", tap_output);
    
    // Generate JSON output  
    let json_reporter = JsonReporter::new(suite_results);
    let json_output = json_reporter.generate_json();
    println!("JSON Output:\n{}", json_output);
}