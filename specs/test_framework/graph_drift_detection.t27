fn parse_tolerance_tier(tier_str: string) -> ToleranceTier {
    match tier_str {
        "EXACT" => ToleranceTier::EXACT,
        "CONJECTURAL" => ToleranceTier::CONJECTURAL,
        "WITHIN_UNCERTAINTY" => ToleranceTier::WITHIN_UNCERTAINTY,
        _ => ToleranceTier::WITHIN_UNCERTAINTY,
    }
}