// specs/github/prs.t27
module github::prs {
    const PR_STATE_OPEN : str = "open";

    struct PullRequest {
        id: u32,
        number: u32,
        title: str,
        state: str,
    }

    fn pr_list(state: str, limit: u32) -> [PullRequest] {
        var prs : [0]PullRequest = undefined;
        return prs;
    }

    test "pr_list_respects_limit"
        const prs = pr_list("open", 5);
        assert(prs.len <= 5);
}
