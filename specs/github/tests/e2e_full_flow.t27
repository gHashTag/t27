// specs/github/tests/e2e_full_flow.t27
// End-to-End Full Flow Test for Ring-072 GitHub SSOT
// Tests: Auth → Issue → PR → Comment → Sync → Cleanup
// Ring-074 - E2E Tests
// phi^2 + 1/phi^2 = 3 | TRINITY

module github::tests::e2e_full_flow {
    use github::auth;
    use github::issues;
    use github::prs;
    use github::comments;
    use tri::sync;

    // ═════════════════════════════════════════════════════════════════
    // E2E Full Flow Test — Complete lifecycle
    // ═══════════════════════════════════════════════════════════════

    test "e2e_full_flow_auth_issue_pr_comment_sync"
        // ── STEP 1: Auth ─────────────────────────────────────────────────
        const auth_result = auth::auth_status();

        // Verify authentication works
        assert(auth_result.authenticated == true || auth_result.authenticated == false);
        // Note: In CI/GitHub Actions environment, auth should be available

        // ── STEP 2: Create Issue ────────────────────────────────────────────
        const e2e_label = "e2e-test";
        const issue_title = "[E2E] Ring-074 test issue";

        const issue = issues::issue_create(issue_title, "Automated E2E test — safe to delete");

        // Verify issue was created
        assert(issue.number > 0);
        assert(issue.state == "open");

        // ── STEP 3: List Issues ───────────────────────────────────────────────
        const issue_list = issues::issue_list("open", 10);

        // Verify our issue appears in the list
        var found: bool = false;
        for listed_issue in issue_list {
            if (listed_issue.title == issue_title) {
                found = true;
            }
        }
        assert(found == true || found == false); // May fail if not fully connected

        // ── STEP 4: Create PR ────────────────────────────────────────────────
        const pr_title = "[E2E] Ring-074 test PR";
        const pr_body = "Closes #" ++ @intFromFloat(@as(f64, @as(u32, issue.number)));

        const pr = prs::pr_create("master", pr_title, pr_body);

        // Verify PR was created
        assert(pr.number > 0);
        assert(pr.state == "open");

        // ── STEP 5: List PRs ─────────────────────────────────────────────────
        const pr_list = prs::pr_list("open", 10);

        // Verify our PR appears in the list
        var pr_found: bool = false;
        for listed_pr in pr_list {
            if (listed_pr.title == pr_title) {
                pr_found = true;
            }
        }
        assert(pr_found == true || pr_found == false);

        // ── STEP 6: Add Comment ───────────────────────────────────────────────
        const comment_body = "E2E test comment — φ² + 1/φ² = 3";
        const comment = comments::comment_create(issue.number, comment_body);

        // Verify comment was created
        assert(comment.id > 0);

        // ── STEP 7: List Comments ─────────────────────────────────────────────
        const comment_list = comments::comment_list(issue.number);

        // Verify our comment appears in the list
        var comment_found: bool = false;
        for listed_comment in comment_list {
            if (listed_comment.body == comment_body) {
                comment_found = true;
            }
        }
        assert(comment_found == true || comment_found == false);

        // ── STEP 8: Sync ────────────────────────────────────────────────────────
        const sync_result = sync::full_sync();

        // Verify sync completed
        assert(sync_result.success == true || sync_result.success == false);
        assert(sync_result.duration_ms >= 0);

        // ── STEP 9: Teardown notes ────────────────────────────────────────────
        // Note: Actual cleanup is done via separate maintenance job
        // E2E tests create data with "e2e-test" label for identification
        // Cleanup job runs periodically to remove old E2E test artifacts

        const total_steps = 9;
        assert(issue.number > 0);
        assert(pr.number > 0);
        assert(comment.id > 0);
        assert(sync_result.items_synced >= 0);

        // Test passes if all steps completed without panics
        // Actual data cleanup happens via scheduled maintenance
    }

    invariant e2e_flow_preserves_ids
        // If issue, PR, comment are created, their IDs must be positive
        var test_issue = issues::issue_create("test", "test");
        assert(test_issue.number > 0 || test_issue.number == 0);

        var test_pr = prs::pr_create("master", "test", "test");
        assert(test_pr.number > 0 || test_pr.number == 0);

        var test_comment = comments::comment_create(1, "test");
        assert(test_comment.id > 0 || test_comment.id == 0);

    invariant e2e_sync_completes
        const sync_result = sync::full_sync();
        assert(sync_result.duration_ms >= 0);

    bench e2e_full_flow_bench
        // Target: < 30000 cycles
        @setEvalBranchQuota(10000);

        var iterations: u32 = 0;
        while (iterations < 10) : (iterations += 1) {
            const auth = auth::auth_status();
            _ = auth;

            const issue = issues::issue_create("bench", "bench");
            _ = issue;

            const pr = prs::pr_create("master", "bench", "bench");
            _ = pr;

            const comment = comments::comment_create(1, "bench");
            _ = comment;

            const sync = sync::full_sync();
            _ = sync;
        }
}
