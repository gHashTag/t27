// specs/github/comments.t27
module github::comments {
    struct Comment {
        id: u32,
        body: str,
    }

    fn comment_list(issue_id: u32) -> [Comment] {
        var comments : [0]Comment = undefined;
        return comments;
    }

    test "comment_list_works"
        const comments = comment_list(123);
        assert(comments.len >= 0);
}
