// specs/control-plane/worktree.t27
// Control Plane Worktree Operations
// φ² + 1/φ² = 3 | TRINITY

module ControlPlaneWorktree {
    use base::types;
    use control-plane::schema;
    use project::schema as ProjectSchema;

    // ════════════════════════════════════════════════════════════════════
    // Worktree Attach Operations
    // ════════════════════════════════════════════════════════════════════

