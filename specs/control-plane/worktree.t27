        workspaceID: WorkspaceID,
        projectID: ProjectSchema::ProjectID,
        branch: str?,            // Branch to checkout
        commit: str?,           // Specific commit to checkout
        directory: str,         // Local directory for worktree
    }

    // attach attaches a worktree to a workspace
    fn attach(input: AttachInput) -> Result<WorkspaceInfo, WorktreeError> {
        // Implementation: Create git worktree and register
    }

    // detach detaches a worktree from its workspace
    fn detach(workspaceID: WorkspaceID, remove: bool) -> Result<void, WorktreeError> {
        // Implementation: Unregister and optionally remove worktree
    }

    // ════════════════════════════════════════════════════════════════════
    // Worktree Sync Operations
    // ════════════════════════════════════════════════════════════════════

    // sync syncs changes between worktree and base repo
    fn sync(workspaceID: WorkspaceID) -> Result<WorktreeSyncResult, WorktreeError> {
        // Implementation: Rebase/merge worktree changes
    }

    // sync_all syncs all worktrees for a project
    fn sync_all(projectID: ProjectSchema::ProjectID) -> Result<[WorktreeSyncResult], WorktreeError> {
        // Implementation: Sync each worktree sequentially
    }

    // sync_status returns the sync status of a worktree
    fn sync_status(workspaceID: WorkspaceID) -> Result<WorktreeSyncStatus, WorktreeError> {
        // Implementation: Check if worktree is ahead/behind/diverged
