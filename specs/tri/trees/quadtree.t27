// Free tree | φ² + 1/φ² = 3 | TRINITY

module TriQuadtree;
    use base::types;
    use math::constants;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const Rect = struct {
        x : "f64",
        y : "f64",
        width : "f64",
        height : "f64",
    };

    pub const QuadNode = struct {
        boundary : "Rect",
        children : [[4]?QuadNode",
        points : [[][2,
        divided : "bool",
        allocator : "std.mem.Allocator",
    };

    pub const QuadTree = struct {
        root : "?QuadNode",
        capacity : "usize",
        allocator : "std.mem.Allocator",
    };

