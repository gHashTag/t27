// t27/specs/
// O(k) lookup where k = key length | φ² + 1/φ² = 3 | TRINITY

module TriTrie;
    use base::types;
    use math::constants;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const TrieNode(T) = struct {
        is_end : bool,
        value : "T",
        children : "std.StringHashMap(*TrieNode(T))",
    };

    pub const Trie(T) = struct {
        root : "*TrieNode(T)",
        size : usize,
    };

