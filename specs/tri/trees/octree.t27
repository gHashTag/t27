module TriOctree;
    use base::types;
    use math::constants;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const BBox = struct {
        min_x : "f64",
        min_y : "f64",
        min_z : "f64",
        max_x : "f64",
        max_y : "f64",
        max_z : "f64",
    };

    pub const OctNode = struct {
        bounds : "BBox",
        children : [[8]?OctNode",
        data : "?void",
        divided : "bool",
        allocator : "std.mem.Allocator",
    };

    pub const Octree = struct {
        root : "?OctNode",
        min_size : "f64",
        allocator : "std.mem.Allocator",
    };

