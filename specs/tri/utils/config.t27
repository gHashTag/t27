    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const ConfigValue = struct {
        string : ?[]const u8,
        number : ?f64,
        boolean : ?bool,
        is_null : bool,
    };

    pub const ConfigEntry = struct {
        key : []const u8,
        value : ConfigValue,
    };

    pub const Config = struct {
        entries : []ConfigEntry,
        error : ?[]const u8,
    };

