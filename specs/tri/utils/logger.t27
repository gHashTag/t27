    pub const Level = struct {
        enum : [Trace, Debug, Info, Warn, Error, Fatal],
    };

    pub const LogEntry = struct {
        timestamp : "Instant",
        level : "Level",
        message : [[]Const u8",
    };

    pub const Logger = struct {
        min_level : "Level",
        writers : [[]LogWriter",
    };

