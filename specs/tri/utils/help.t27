// t27/specs/
//  | φ² + 1/φ² = 3 | TRINITY

module TriHelp;
    use base::types;
    use math::constants;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const HelpOptions = struct {
        category : ?CommandCategory  # default: null,
        search : ?[]const U8         # default: null,
        verbose : Bool               # default: false,
    };

    pub const HelpSystem = struct {
        registry : *const CommandRegistry,
        allocator : Std.mem.Allocator,
        terminal_width : Usize  # default: 80,
    };

    // ═══════════════════════════════════════════════════════════
    // TDD: Tests (from .tri behaviors)
    // ═══════════════════════════════════════════════════════════

    invariant "help_init_succeeds" {
        given ctx = default_context()
        when result = help_init(ctx)
        then result.status == ok
    }

    test "help_roundtrip" {
        given input = default_input()
        when output = process(input)
        then output != undefined
    }
