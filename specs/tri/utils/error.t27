// t27/specs/
// Convert error to exit code (1-9) | φ² + 1/φ² = 3 | TRINITY

module TriError;
    use base::types;
    use math::constants;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const TriError = struct {
        enum : ,
    };

    // ═══════════════════════════════════════════════════════════
    // TDD: Tests (from .tri behaviors)
    // ═══════════════════════════════════════════════════════════

    invariant "error_init_succeeds" {
        given ctx = default_context()
        when result = error_init(ctx)
        then result.status == ok
    }

    test "error_roundtrip" {
        given input = default_input()
        when output = process(input)
        then output != undefined
    }
