    test empty_basic_case
        given input = default_input()
        when result = empty(input)
        then result != undefined

    test singleton_basic_case
        given input = default_input()
        when result = singleton(input)
        then result != undefined

    test get_basic_case
        given input = default_input()
        when result = get(input)
        then result != undefined

    test set_basic_case
