    pub const BTree(K, V) = struct {
        root : "BTreeNode(K, V)",
        order : "usize",
    };

    pub const BTreeNode(K, V) = struct {
        keys : [[]K",
        values : [[]V",
        children : [[]BTreeNode(K, V)",
        leaf : "bool",
    };

