// specs/tri/sync.t27
module tri::sync {
    struct SyncResult {
        success: bool,
        items_synced: u32,
    }

    fn full_sync() -> SyncResult {
        var result : SyncResult = undefined;
        result.success = false;
        return result;
    }

    test "full_sync_completes"
        const result = full_sync();
        assert(result.duration_ms >= 0);
}
