    pub const MsgPackType = struct {
        enum : [Nil, Bool, Int, Uint, Float, Str, Bin, Array, Map],
    };

    pub const MsgPackValue = struct {
        type : "MsgPackType",
        int_value : "i64",
        uint_value : "u64",
        float_value : "f64",
        str_value : [[]Const u8",
        bin_value : [[]Const u8",
        array_value : [[]MsgPackValue",
        map_value : "std.StringHashMap(MsgPackValue)",
    };

