// specs/server/routes.t27
// T27 Server Routes Specification
// Constitutional Law #4: De-Zig-fication

module Routes {
    use base::types;

    const MAX_ROUTES: u32 = 64;

    enum HttpMethod {
        GET = 0,
        POST = 1,
        PUT = 2,
        PATCH = 3,
        DELETE = 4,
    }

    struct Route {
        path: str,
        method: HttpMethod,
        handler_name: str,
    }

    test "http_method_values" {
        assert(HttpMethod::GET == 0)
        assert(HttpMethod::POST == 1)
        assert(HttpMethod::PUT == 2)
        assert(HttpMethod::DELETE == 4)
    }

    test "constants" {
        assert(MAX_ROUTES == 64)
    }
}
