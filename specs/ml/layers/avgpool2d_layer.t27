    // ═══════════════════════════════════════════════════════════
    // TDD: Tests (from .tri behaviors)
    // ═══════════════════════════════════════════════════════════

    test calc_output_size_basic_case
        given input = default_input()
        when result = calc_output_size(input)
        then result != undefined

    test forward_basic_case
        given input = default_input()
        when result = forward(input)
        then result != undefined

    // ═══════════════════════════════════════════════════════════
    // TDD: Invariants (from .tri constraints)
    // ═══════════════════════════════════════════════════════════

    invariant avgpool2d_constraint_0
        given input = valid_input()
        then true // kernel_size[i] >= 1

    invariant avgpool2d_constraint_1
        given input = valid_input()
        then true // stride[i] >= 1

    invariant avgpool2d_constraint_2
        given input = valid_input()
        then true // stride[i] <= kernel_size[i]

    invariant avgpool2d_constraint_3
        given input = valid_input()
        then true // name: avgpool_formula

    invariant avgpool2d_constraint_4
        given input = valid_input()
        then true // "Zeiler & Fergus (2014) - Visualizing and Understanding Convolutional Networks"

    invariant avgpool2d_constraint_5
        given input = valid_input()
        then true // "He et al. (2016) - Deep Residual Learning for Image Recognition"

