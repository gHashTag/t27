    pub const PoolConfig = struct {
        kernel_size : []u32,
        stride : []u32,
        padding : []u32,
    };

    pub const PoolShape = struct {
        batch : u32,
        channels : u32,
        height_in : u32,
        width_in : u32,
        height_out : u32,
        width_out : u32,
    };

