// t27/specs/
// Optimized depthwise convolution | φ² + 1/φ² = 3 | TRINITY

module Conv2d;
    use base::types;
    use math::constants;

    // ═══════════════════════════════════════════════════════════
    // 1. Constants
    // ═══════════════════════════════════════════════════════════

    const MIN_KERNEL_SIZE : u32 = 1;
    const MAX_KERNEL_SIZE : u32 = 7;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const Conv2DConfig = struct {
        in_channels : u32,
        out_channels : u32,
        kernel_size : u32,
        stride : u32,
        padding : u32,
        dilation : u32,
        groups : u32,
        has_bias : bool,
    };

    pub const PaddingMode = struct {
        enum_type : "enum",
        values : ,
        Zeros : Auto,
        Reflect : Auto,
        Replicate : Auto,
        Circular : Auto,
    };

    // ═══════════════════════════════════════════════════════════
    // 3. Core Functions
    // ═══════════════════════════════════════════════════════════

