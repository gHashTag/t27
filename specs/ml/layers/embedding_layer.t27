    const DEFAULT_D_MODEL : u32 = 64;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const EmbeddingConfig = struct {
        vocab_size : u32,
        d_model : u32,
    };

    pub const EmbeddingWeights = struct {
        W : []f32,
    };

    // ═══════════════════════════════════════════════════════════
    // 3. Core Functions
