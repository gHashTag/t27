    const DEFAULT_LR : f32 = 0.01;
    const DEFAULT_EPSILON : f32 = 1e-8;
    const DEFAULT_WEIGHT_DECAY : f32 = 0.0;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const AdagradConfig = struct {
        learning_rate : f32,
        epsilon : f32,
        weight_decay : f32,
    };

    pub const AdagradState = struct {
        sum_squared_grad : []f32,
    };

    // ═══════════════════════════════════════════════════════════
