    // ═══════════════════════════════════════════════════════════
    // TDD: Tests (from .tri behaviors)
    // ═══════════════════════════════════════════════════════════

    test compute_td_residual_basic_case
        given input = default_input()
        when result = compute_td_residual(input)
        then result != undefined

    test compute_gae_basic_case
