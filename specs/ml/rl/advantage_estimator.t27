    // TDD: Invariants (from .tri constraints)
    // ═══════════════════════════════════════════════════════════

    invariant advantage_constraint_0
        given input = valid_input()
        then true // 0 <= gamma <= 1

    invariant advantage_constraint_1
        given input = valid_input()
        then true // 0 <= lambda_ <= 1

    invariant advantage_constraint_2
        given input = valid_input()
