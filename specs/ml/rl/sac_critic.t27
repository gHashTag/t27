    const DEFAULT_TAU : f32 = 0.005;
    const DEFAULT_GAMMA : f32 = 0.99;
    const DEFAULT_INIT_WEIGHT : f32 = 0.003;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const SACCriticConfig = struct {
        state_dim : u32,
        action_dim : u32,
        hidden_dims : []u32,
        init_weight : f32,
    };

    pub const TwinQOutput = struct {
        q1 : f32,
        q2 : f32,
    };

    pub const TargetQUpdate = struct {
        tau : f32,
        gamma : f32,
    };

