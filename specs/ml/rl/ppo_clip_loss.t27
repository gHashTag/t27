    pub const PPOClipConfig = struct {
        clip_epsilon : f32,
        entropy_coef : f32,
        value_clip_coef : f32,
    };

    pub const PPOBatch = struct {
        states : [][]f32,
        actions : [][]f32,
        old_log_probs : []f32,
        advantages : []f32,
        returns : []f32,
        values : []f32,
    };

