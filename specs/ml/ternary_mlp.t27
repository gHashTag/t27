    bench mlp_create_latency
        measure: nanoseconds to mlp_xor_create()
        target: < 1000ns

    bench mlp_forward_latency_2_9_1
        measure: nanoseconds to mlp_forward(test_mlp_2_9_1, test_inputs_gf16_2)
        target: < 5000ns

    bench mlp_predict_latency
        measure: nanoseconds to mlp_predict(test_mlp_2_9_1, [gf16::gf16_encode_f32(1.0), gf16::gf16_encode_f32(0.0)])
        target: < 3000ns

    bench mlp_train_xor_100_epochs
        measure: microseconds to mlp_train_xor(&test_mlp_mutable, training_config_100_epochs())
        target: < 100000us

    bench mlp_compute_accuracy_xor
        measure: nanoseconds to mlp_compute_accuracy(test_mlp_2_9_1)
        target: < 5000ns

