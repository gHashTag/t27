    invariant mlp_layer_count_matches_hidden_plus_one
        given hidden_sizes = [3, 5, 7]
        and   arch = MLPArchitecture{
            .input_size = 2,
            .hidden_sizes = hidden_sizes,
            .output_size = 1,
            .activation = ternary_neuron::ACT_K3,
            .output_activation = ternary_neuron::ACT_K3,
        }
        and   mlp = mlp_create(arch)
        then len(mlp.layers) == len(hidden_sizes) + 1

    invariant mlp_forward_preserves_batch_size
        given mlp = mlp_xor_create()
        and   batch_size = 10
        and   inputs = [[gf16::gf16_encode_f32(0.0), gf16::gf16_encode_f32(0.0)], [gf16::gf16_encode_f32(0.0), gf16::gf16_encode_f32(1.0)], [gf16::gf16_encode_f32(1.0), gf16::gf16_encode_f32(0.0)], [gf16::gf16_encode_f32(1.0), gf16::gf16_encode_f32(1.0)], [gf16::gf16_encode_f32(0.5), gf16::gf16_encode_f32(0.5)], [gf16::gf16_encode_f32(0.5), gf16::gf16_encode_f32(1.0)], [gf16::gf16_encode_f32(1.0), gf16::gf16_encode_f32(0.5)], [gf16::gf16_encode_f32(1.0), gf16::gf16_encode_f32(1.0)], [gf16::gf16_encode_f32(0.0), gf16::gf16_encode_f32(0.5)]]
        when output = mlp_forward(mlp, inputs)
        then len(output) == batch_size

    invariant mlp_predict_confidence_in_bounds
        given mlp = mlp_xor_create()
        and   inputs = [[gf16::gf16_encode_f32(0.0), gf16::gf16_encode_f32(0.0)], [gf16::gf16_encode_f32(0.0), gf16::gf16_encode_f32(1.0)], [gf16::gf16_encode_f32(1.0), gf16::gf16_encode_f32(0.0)], [gf16::gf16_encode_f32(1.0), gf16::gf16_encode_f32(1.0)]]
        and   all_valid = all_predictions_valid(mlp, inputs)
        then all_valid == true

    invariant mlp_architecture_preserved
        given original = MLPArchitecture{
            .input_size = 5,
            .hidden_sizes = [7, 11],
            .output_size = 3,
            .activation = ternary_neuron::ACT_SIGN,
            .output_activation = ternary_neuron::ACT_K3,
        }
        and   mlp = mlp_create(original)
        and   stored = mlp.architecture
        then stored.input_size == original.input_size
        then len(stored.hidden_sizes) == len(original.hidden_sizes)
        then stored.output_size == original.output_size
        then stored.activation == original.activation
        then stored.output_activation == original.output_activation

    invariant mlp_accuracy_in_range
        given mlp = mlp_xor_create()
        and   acc = mlp_compute_accuracy(mlp)
        and   acc_f32 = gf16::gf16_decode_to_f32(acc)
        then acc_f32 >= 0.0 and acc_f32 <= 1.0

    invariant training_history_non_empty
        given mlp = mlp_xor_create()
        and   config = default_training_config()
        when history = mlp_train_xor(&mlp, config)
        then len(history.losses) > 0
        then history.epochs_trained > 0

    // ═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════