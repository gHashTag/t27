    pub const GRUConfig = struct {
        input_size : u32,
        hidden_size : u32,
    };

    pub const GRUState = struct {
        h : []f32,
    };

    pub const GRUWeights = struct {
        Wr : []f32,
        br : []f32,
        Wz : []f32,
        bz : []f32,
        Wh : []f32,
        bh : []f32,
    };

    // ═══════════════════════════════════════════════════════════
