module Lstm;
    use base::types;
    use math::constants;

    // ═══════════════════════════════════════════════════════════
    // 1. Constants
    // ═══════════════════════════════════════════════════════════

    const LSTM_DEFAULT_HIDDEN : u32 = 128;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const LSTMConfig = struct {
        input_size : u32,
        hidden_size : u32,
    };

    pub const LSTMState = struct {
        h : []f32,
        c : []f32,
    };

    pub const LSTMWeights = struct {
        Wf : []f32,
        bf : []f32,
        Wi : []f32,
        bi : []f32,
        Wo : []f32,
        bo : []f32,
        Wg : []f32,
        bg : []f32,
    };

    // ═══════════════════════════════════════════════════════════
    // 3. Core Functions
    // ═══════════════════════════════════════════════════════════

    // forward(input: []const f32) → void
