    const FORGET_BIAS_INIT : f32 = 1.0;

    // ═══════════════════════════════════════════════════════════
    // 2. Types
    // ═══════════════════════════════════════════════════════════

    pub const LSTMConfig = struct {
        input_size : u32,
        hidden_size : u32,
    };

    pub const LSTMState = struct {
        h : []f32,
        c : []f32,
    };

    pub const LSTMWeights = struct {
        W_ii : []f32,
        W_hi : []f32,
        b_i : []f32,
        W_if : []f32,
        W_hf : []f32,
        b_f : []f32,
        W_ig : []f32,
        W_hg : []f32,
        b_g : []f32,
        W_io : []f32,
        W_ho : []f32,
        b_o : []f32,
    };

    // ═══════════════════════════════════════════════════════════
