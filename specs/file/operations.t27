    // ════════════════════════════════════════════════════════════════════
    // Tests
    // ════════════════════════════════════════════════════════════════════

    test "file_type_values" {
        assert(FileType::File as u32 == 0);
        assert(FileType::Directory as u32 == 1);
        assert(FileType::Symlink as u32 == 2);
    }

    test "file_status_values" {
        assert(FileStatus::Added as u32 == 0);
        assert(FileStatus::Deleted as u32 == 1);
        assert(FileStatus::Modified as u32 == 2);
    }

    test "content_type_values" {
        assert(ContentType::Text as u32 == 0);
        assert(ContentType::Binary as u32 == 1);
        assert(ContentType::Image as u32 == 2);
    }

    test "file_error_values" {
        assert(FileError::NotFound as u32 == 0);
        assert(FileError::PermissionDenied as u32 == 1);
        assert(FileError::IsDirectory as u32 == 2);
        assert(FileError::NotDirectory as u32 == 3);
        assert(FileError::AccessDenied as u32 == 4);
        assert(FileError::InvalidPath as u32 == 5);
        assert(FileError::ReadError as u32 == 6);
        assert(FileError::WriteError as u32 == 7);
        assert(FileError::DeleteError as u32 == 8);
    }

    test "file_info_creation" {
        var info = FileInfo {
            path = "test.txt",
            fileType = FileType::File,
            size = 100,
            modified = 1234567890,
            permissions = 644,
            isHidden = false,
            isIgnored = false,
        };
        assert(info.path == "test.txt");
        assert(info.fileType == FileType::File);
    }

    test "file_content_text" {
        var content = FileContent {
            type = ContentType::Text,
            content = "hello",
            diff = null,
            mimeType = "text/plain",
            encoding = null,
            lineCount = 1,
        };
        assert(is_text(content.type));
    }

    test "file_node_creation" {
        var node = FileNode {
            name = "test.txt",
            path = "test.txt",
            absolute = "/home/test.txt",
            fileType = FileType::File,
            ignored = false,
            children = null,
        };
        assert(node.name == "test.txt");
        assert(node.fileType == FileType::File);
    }

    test "file_change_creation" {
        var change = FileChange {
            path = "test.txt",
            status = FileStatus::Modified,
            additions = 5,
            deletions = 2,
        };
        assert(change.status == FileStatus::Modified);
    }

    test "ignore_pattern_creation" {
        var pattern = IgnorePattern {
            pattern = "node_modules",
            isDir = true,
        };
        assert(pattern.pattern == "node_modules");
    }

    test "ignore_rules_creation" {
        var patterns = [
            IgnorePattern {
                pattern = "*.log",
                isDir = false,
            },
        ];
        var rules = IgnoreRules {
            patterns = patterns,
            whitelists: [],
        };
        assert(rules.patterns.len == 1);
    }

    test "search_match_creation" {
        var match = SearchMatch {
            path = "test.txt",
            line = 1,
            content = "test line",
            start = 0,
            end = 4,
        };
        assert(match.path == "test.txt");
    }

    test "search_options_creation" {
        var options = SearchOptions {
            query = "test",
            pattern = null,
            caseSensitive = false,
            maxResults = 100,
            includeHidden = false,
            fileType = null,
        };
        assert(options.query == "test");
    }

    test "constants_values" {
        assert(MAX_FILE_SIZE == 10485760);
        assert(MAX_SEARCH_RESULTS == 1000);
        assert(DEFAULT_READ_CHUNK == 8192);
    }

    test "is_text_true" {
        assert(is_text(ContentType::Text));
    }

    test "is_binary_true" {
        assert(is_binary(ContentType::Binary));
    }

    test "is_image_true" {
        assert(is_image(ContentType::Image));
    }

    test "is_hidden_true" {
        assert(is_hidden(".git"));
        assert(is_hidden("path/.hidden"));
    }

    test "is_hidden_false" {
        assert(!is_hidden("visible"));
        assert(!is_hidden("."));
    }

    test "get_extension_simple" {
        assert(get_extension("test.txt") == "txt");
        assert(get_extension("file.tar.gz") == "gz");
    }

    test "get_extension_none" {
        assert(get_extension("README") == "");
        assert(get_extension("path/to/file") == "");
    }

    test "watch_event_creation" {
        var event = WatchEvent {
            path = "test.txt",
            eventType = WatchEventType::Change,
            timestamp = 1234567890,
        };
        assert(event.eventType == WatchEventType::Change);
    }

    test "watcher_handle_creation" {
        var handle = WatcherHandle {
            id = "watch-1",
            paths: ["/home/project"],
            active = true,
        };
        assert(handle.active);
    }

    test "submatch_creation" {
        var submatch = Submatch {
            match = "test",
            start = 0,
            end = 4,
        };
        assert(submatch.match == "test");
    }

    test "ripgrep_match_creation" {
        var submatches = [
            Submatch {
                match = "pattern",
                start = 5,
                end = 12,
            },
        ];
        var match = RipgrepMatch {
            path = "test.ts",
            lineNumber = 10,
            content = "const pattern = /test/",
            submatches = submatches,
        };
        assert(match.path == "test.ts");
    }

    test "ripgrep_options_creation" {
        var globs = ["*.ts", "*.js"];
        var options = RipgrepOptions {
            glob = globs,
            hidden = true,
            follow = false,
            maxDepth = 10,
            limit = 100,
        };
        assert(options.glob?.len == 2);
        assert(options.maxDepth == 10);
    }

    test "file_info_directory" {
        var info = FileInfo {
            path = "src",
            fileType = FileType::Directory,
            size = 0,
            modified = 1234567890,
            permissions = 755,
            isHidden = false,
            isIgnored = false,
        };
        assert(info.fileType == FileType::Directory);
    }

    test "file_content_binary" {
        var content = FileContent {
            type = ContentType::Binary,
            content = "",
            diff = null,
            mimeType = "application/octet-stream",
            encoding = null,
            lineCount = null,
        };
        assert(is_binary(content.type));
    }

    test "file_content_image" {
        var content = FileContent {
            type = ContentType::Image,
            content = "base64data",
            diff = null,
            mimeType = "image/png",
            encoding = "base64",
            lineCount = null,
        };
        assert(is_image(content.type));
    }

    test "file_node_directory_with_children" {
        var children = [
            FileNode {
                name = "file.txt",
                path = "dir/file.txt",
                absolute = "/abs/dir/file.txt",
                fileType = FileType::File,
                ignored = false,
                children = null,
            },
        ];
        var node = FileNode {
            name = "dir",
            path = "dir",
            absolute = "/abs/dir",
            fileType = FileType::Directory,
            ignored = false,
            children = children,
        };
        assert(node.children?.len == 1);
    }

    test "normalize_empty_path" {
        assert(normalize("") == ".");
    }

    test "normalize_dot" {
        assert(normalize(".") == ".");
    }

    test "join_empty" {
        assert(join([]) == ".");
    }

    test "join_single" {
        assert(join(["path"]) == "path");
    }

    test "join_multiple" {
        var result = join(["home", "user", "file.txt"]);
        assert(result == "home/user/file.txt");
    }

    test "dirname_simple" {
        assert(dirname("path/to/file.txt") == "path/to");
    }

    test "dirname_no_slash" {
        assert(dirname("file.txt") == ".");
    }

    test "basename_simple" {
        assert(basename("path/to/file.txt") == "file.txt");
    }

    test "basename_no_slash" {
        assert(basename("file.txt") == "file.txt");
    }

    test "extname_simple" {
        assert(extname("file.txt") == ".txt");
    }

    test "extname_no_extension" {
        assert(extname("README") == "");
    }

    test "extname_multiple_dots" {
        assert(extname("file.tar.gz") == ".gz");
    }

    test "count_lines_empty" {
        assert(count_lines("") == 1);
    }

    test "count_lines_single" {
        assert(count_lines("line") == 1);
    }

    test "count_lines_multiple" {
        assert(count_lines("line1\nline2\nline3") == 3);
    }

    test "truncate_no_truncation" {
        var result = truncate("short", 100);
        assert(result == "short");
    }

    test "truncate_with_truncation" {
        var result = truncate("this is a very long string that needs truncation", 10);
        assert(result.len <= 13); // "..." added
    }

    test "detect_type_text_file" {
        var result = detect_type("test.txt", "hello world");
        assert(result == ContentType::Text);
    }

    test "is_ignored_with_pattern" {
        var patterns = [
            IgnorePattern {
                pattern = "*.log",
                isDir = false,
            },
        ];
        var rules = IgnoreRules {
            patterns = patterns,
            whitelists: [],
        };
        assert(is_ignored("debug.log", rules));
    }

    test "is_ignored_whitelisted" {
        var patterns = [
            IgnorePattern {
                pattern = "*.log",
                isDir = false,
            },
        ];
        var rules = IgnoreRules {
            patterns = patterns,
            whitelists: ["important.log"],
        };
        assert(!is_ignored("important.log", rules));
    }

    test "add_ignore_pattern" {
        var rules = IgnoreRules {
            patterns = [],
            whitelists: [],
        };
        var newRules = add_ignore_pattern(rules, "node_modules/");
        assert(newRules.patterns.len == 1);
    }

    test "resolve_relative_path" {
        var result = resolve("/home/user", "project/file.txt");
        assert(result == "/home/user/project/file.txt");
    }

    test "resolve_absolute_path" {
        var result = resolve("/home/user", "/tmp/file.txt");
        assert(result == "/tmp/file.txt");
    }
}
