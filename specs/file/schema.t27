                isDir = false,
            },
            IgnorePattern {
                pattern = "node_modules",
                isDir = true,
            },
        ];
        var rules = IgnoreRules {
            patterns = patterns,
            whitelists: ["important.log"],
        };
        assert(rules.patterns.len == 2);
        assert(rules.whitelists.len == 1);
    }

