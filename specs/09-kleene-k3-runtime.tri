}

bench k3_consensus_throughput {
  measure nanoseconds to k3_consensus([K3Trit::POS, K3Trit::NEG, K3Trit::POS, K3Trit::NEG, K3Trit::NEU, K3Trit::NEG])
  target 100_000_000  -- 100M ops/sec
  warmup 3
  runs 50
}

bench k3_not_throughput {
  measure nanoseconds to k3_not(K3Trit::POS)
  target 500_000_000  -- 500M ops/sec
  warmup 3
  runs 50
}
