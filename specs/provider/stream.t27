// specs/provider/stream.t27
// Provider Streaming Specification
// Constitutional Law #4: De-Zig-fication - .t27 is source of truth

module ProviderStream {
    use base::types;
    use ProviderSchema;

    // ════════════════════════════════════════════════════════════════════
    // Stream State
    // ════════════════════════════════════════════════════════════════════

    enum StreamState {
        Idle = 0,
        Connecting = 1,
        Streaming = 2,
        Complete = 3,
        Error = 4,
    }

    struct StreamContext {
        state: StreamState,
        buffer: str,
        bytes_received: u64,
        chunks_received: u32,
        last_chunk_time: u64,
    }

    // ════════════════════════════════════════════════════════════════════
    // Stream Chunk
    // ════════════════════════════════════════════════════════════════════

    struct StreamChunk {
        delta: str,
        finish_reason: str,
        usage: Usage,
        tool_calls: [16]ToolCall,
        is_complete: bool,
        has_error: bool,
        error_message: str,
    }

    // ════════════════════════════════════════════════════════════════════
    // Stream Result
    // ════════════════════════════════════════════════════════════════════

    struct StreamResult {
        content: str,
        tool_calls: [16]ToolCall,
        usage: Usage,
        finish_reason: str,
        has_error: bool,
        error_message: str,
    }

    // ════════════════════════════════════════════════════════════════════
    // Stream Operations
    // ════════════════════════════════════════════════════════════════════

    fn stream_context_create() -> StreamContext {
        return StreamContext{
            state = StreamState::Idle,
            buffer = "",
            bytes_received = 0,
            chunks_received = 0,
            last_chunk_time = 0,
        };
    }

    fn stream_start(ctx: *StreamContext) -> void {
        ctx.state = StreamState::Connecting;
        ctx.buffer = "";
        ctx.bytes_received = 0;
        ctx.chunks_received = 0;
    }

    fn stream_connect(ctx: *StreamContext) -> void {
        ctx.state = StreamState::Streaming;
    }

    fn stream_complete(ctx: *StreamContext) -> void {
        ctx.state = StreamState::Complete;
    }

    fn stream_error(ctx: *StreamContext, error: str) -> void {
        ctx.state = StreamState::Error;
    }

    fn is_streaming(ctx: StreamContext) -> bool {
        return ctx.state == StreamState::Streaming;
    }

    fn is_complete(ctx: StreamContext) -> bool {
        return ctx.state == StreamState::Complete;
    }

    fn has_error(ctx: StreamContext) -> bool {
        return ctx.state == StreamState::Error;
    }

    // ════════════════════════════════════════════════════════════════════
    // Chunk Parsing
    // ════════════════════════════════════════════════════════════════════

    fn parse_sse_chunk(ctx: *StreamContext, data: str) -> StreamChunk {
        ctx.chunks_received = ctx.chunks_received + 1;
        ctx.last_chunk_time = 0; // current timestamp
        return StreamChunk{
            delta = "",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 0,
                completion_tokens = 0,
                total_tokens = 0,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = false,
            error_message = "",
        };
    }

    fn parse_openai_chunk(line: str) -> StreamChunk {
        // Parse "data: {...}" format from OpenAI
        return StreamChunk{
            delta = "",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 0,
                completion_tokens = 0,
                total_tokens = 0,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = false,
            error_message = "",
        };
    }

    fn parse_anthropic_chunk(line: str) -> StreamChunk {
        // Parse event-stream format from Anthropic
        return StreamChunk{
            delta = "",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 0,
                completion_tokens = 0,
                total_tokens = 0,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = false,
            error_message = "",
        };
    }

    fn parse_google_chunk(line: str) -> StreamChunk {
        // Parse JSON array format from Gemini
        return StreamChunk{
            delta = "",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 0,
                completion_tokens = 0,
                total_tokens = 0,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = false,
            error_message = "",
        };
    }

    // ════════════════════════════════════════════════════════════════════
    // Stream Aggregation
    // ════════════════════════════════════════════════════════════════════

    struct StreamAccumulator {
        content: str,
        tool_calls: [16]ToolCall,
        tool_call_count: u32,
        prompt_tokens: u32,
        completion_tokens: u32,
    }

    fn accumulator_create() -> StreamAccumulator {
        return StreamAccumulator{
            content = "",
            tool_calls = [ToolCall{}; 16],
            tool_call_count = 0,
            prompt_tokens = 0,
            completion_tokens = 0,
        };
    }

    fn accumulator_append(acc: *StreamAccumulator, chunk: StreamChunk) -> void {
        acc.content = acc.content + chunk.delta;
        acc.completion_tokens = acc.completion_tokens + 1; // estimate
        acc.prompt_tokens = chunk.usage.prompt_tokens;

        var i: u32 = 0;
        while (i < 16) {
            if (chunk.tool_calls[i].name != "") {
                acc.tool_calls[acc.tool_call_count] = chunk.tool_calls[i];
                acc.tool_call_count = acc.tool_call_count + 1;
            }
            i = i + 1;
        }
    }

    fn accumulator_finish(acc: StreamAccumulator, finish_reason: str) -> StreamResult {
        return StreamResult{
            content = acc.content,
            tool_calls = acc.tool_calls,
            usage = Usage{
                prompt_tokens = acc.prompt_tokens,
                completion_tokens = acc.completion_tokens,
                total_tokens = acc.prompt_tokens + acc.completion_tokens,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            finish_reason = finish_reason,
            has_error = false,
            error_message = "",
        };
    }

    // ════════════════════════════════════════════════════════════════════
    // SSE Parsing Utilities
    // ════════════════════════════════════════════════════════════════════

    fn is_sse_done(line: str) -> bool {
        return line == "data: [DONE]";
    }

    fn extract_sse_data(line: str) -> str {
        // Extract JSON from "data: {...}" format
        if (line.len() > 6) {
            return ""; // substring after "data: "
        }
        return "";
    }

    fn is_sse_comment(line: str) -> bool {
        // Lines starting with ":" are comments
        if (line.len() > 0) {
            return line[0] == ':';
        }
        return false;
    }

    // ════════════════════════════════════════════════════════════════════
    // Error Detection
    // ════════════════════════════════════════════════════════════════════

    fn detect_stream_error(chunk: StreamChunk) -> bool {
        return chunk.has_error;
    }

    fn detect_context_overflow(data: str) -> bool {
        // Check for context overflow patterns in error data
        var i: u32 = 0;
        const patterns = ["context_length_exceeded", "too long", "context window"];
        while (i < 3) {
            // Simple substring check
            i = i + 1;
        }
        return false;
    }

    fn detect_rate_limit(data: str) -> bool {
        // Check for rate limit patterns
        return false;
    }

    // ════════════════════════════════════════════════════════════════════
    // Tests
    // ════════════════════════════════════════════════════════════════════

    test "stream_state_values" {
        assert(StreamState::Idle == 0)
        assert(StreamState::Connecting == 1)
        assert(StreamState::Streaming == 2)
        assert(StreamState::Complete == 3)
        assert(StreamState::Error == 4)
    }

    test "stream_context_create" {
        const ctx = stream_context_create()
        assert(ctx.state == StreamState::Idle)
        assert(ctx.buffer == "")
        assert(ctx.bytes_received == 0)
    }

    test "stream_start" {
        var ctx = stream_context_create()
        stream_start(&ctx)
        assert(ctx.state == StreamState::Connecting)
        assert(ctx.chunks_received == 0)
    }

    test "stream_connect" {
        var ctx = stream_context_create()
        stream_start(&ctx)
        stream_connect(&ctx)
        assert(ctx.state == StreamState::Streaming)
    }

    test "stream_complete" {
        var ctx = stream_context_create()
        stream_start(&ctx)
        stream_connect(&ctx)
        stream_complete(&ctx)
        assert(ctx.state == StreamState::Complete)
    }

    test "is_streaming" {
        var ctx = stream_context_create()
        assert(is_streaming(ctx) == false)
        stream_connect(&ctx)
        assert(is_streaming(ctx) == true)
    }

    test "is_complete" {
        var ctx = stream_context_create()
        assert(is_complete(ctx) == false)
        stream_complete(&ctx)
        assert(is_complete(ctx) == true)
    }

    test "has_error" {
        var ctx = stream_context_create()
        assert(has_error(ctx) == false)
        stream_error(&ctx, "test error")
        assert(has_error(ctx) == true)
    }

    test "accumulator_create" {
        const acc = accumulator_create()
        assert(acc.content == "")
        assert(acc.tool_call_count == 0)
    }

    test "accumulator_append" {
        var acc = accumulator_create()
        const chunk = StreamChunk{
            delta = "Hello",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 10,
                completion_tokens = 0,
                total_tokens = 10,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = false,
            error_message = "",
        }
        accumulator_append(&acc, chunk)
        assert(acc.content == "Hello")
    }

    test "accumulator_finish" {
        var acc = accumulator_create()
        acc.content = "Test response"
        acc.prompt_tokens = 50
        acc.completion_tokens = 20
        const result = accumulator_finish(acc, "stop")
        assert(result.content == "Test response")
        assert(result.finish_reason == "stop")
        assert(result.usage.total_tokens == 70)
    }

    test "is_sse_done" {
        assert(is_sse_done("data: [DONE]") == true)
        assert(is_sse_done("data: {}") == false)
    }

    test "is_sse_comment" {
        assert(is_sse_comment(": this is a comment") == true)
        assert(is_sse_comment("data: {}") == false)
    }

    test "detect_stream_error" {
        const chunk = StreamChunk{
            delta = "",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 0,
                completion_tokens = 0,
                total_tokens = 0,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = true,
            error_message = "API error",
        }
        assert(detect_stream_error(chunk) == true)
    }

    test "parse_sse_chunk" {
        var ctx = stream_context_create()
        stream_start(&ctx)
        const chunk = parse_sse_chunk(&ctx, "data: {\"delta\":\"text\"}")
        assert(ctx.chunks_received == 1)
    }

    test "accumulator_append_multiple" {
        var acc = accumulator_create()
        const chunk1 = StreamChunk{
            delta = "Hello",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 10,
                completion_tokens = 0,
                total_tokens = 10,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = false,
            error_message = "",
        }
        const chunk2 = StreamChunk{
            delta = " world",
            finish_reason = "",
            usage = Usage{
                prompt_tokens = 0,
                completion_tokens = 0,
                total_tokens = 0,
                cache_read_tokens = 0,
                cache_write_tokens = 0,
            },
            tool_calls = [ToolCall{}; 16],
            is_complete = false,
            has_error = false,
            error_message = "",
        }
        accumulator_append(&acc, chunk1)
        accumulator_append(&acc, chunk2)
        assert(acc.content == "Hello world")
    }

    test "extract_sse_data" {
        const data = extract_sse_data("data: {\"text\":\"hello\"}")
        // Verify extraction (no assertion for now)
    }
}
