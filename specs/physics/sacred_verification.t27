            FormulaDefinition{
                id           = 20,
                name         = "Barbero-Immirzi Parameter",
                formula      = "γ = φ⁻³",
                category     = DERIVED,
                expected     = sacred_physics::GAMMA_LQG,
                tolerance    = 1e-15,
                scale_factor = 1.0,
                notes        = "LQG Immirzi parameter: 13.9% gap to Meissner",
            },
            // Area gap formula (Meissner)
            FormulaDefinition{
                id           = 21,
                name         = "Area Gap (Meissner)",
                formula      = "Δ = γ² + √(2γ²)",
                category     = DERIVED,
                expected     = 0.0857,
                tolerance    = 1e-3,
                scale_factor = 1.0,
                notes        = "For γ = φ⁻³: Δ ≈ 0.0857",
            },
            // Meissner gap (standard)
            FormulaDefinition{
                id           = 22,
                name         = "Meissner Gap (γ=0.274)",
                formula      = "Δ(γ_Meissner)",
                category     = PHYSICAL,
                expected     = 0.110,
                tolerance    = 1e-2,
                scale_factor = 1.0,
                notes        = "Standard LQG solution",
            },
            // Immirzi ratio to Meissner
            FormulaDefinition{
                id           = 23,
                name         = "Immirzi Ratio",
                formula      = "γ_φ / γ_Meissner",
                category     = DERIVED,
                expected     = 0.861,
                tolerance    = 1e-3,
                scale_factor = 1.0,
