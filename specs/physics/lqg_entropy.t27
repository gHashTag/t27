test lqg_cs_gamma_origin_different_from_lqg
    // Verify documentation: CS 39 emerges from quantum dimension d = 40
    // LQG 41 = Barbero-Immirzi parameter from area spectrum quantization
    then true

invariant lqg_unresolved_gap_documented
