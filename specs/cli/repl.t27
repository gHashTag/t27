// ============================================================================
// TDD - Tests
// ============================================================================

test "test_repl_init_default_ring" {
    // Verify: repl_init starts at ring 47 with SEED layer
    const state = repl_init();
    try std.testing.expectEqual(@as(u32, 47), state.ring_number);
    try std.testing.expectEqual(@as(u8, 4), state.ring_layer_len);
    try std.testing.expect(state.is_running);
    try std.testing.expectEqual(@as(u16, 0), state.session.count);
    try std.testing.expectEqual(@as(u8, 0), state.plugin_count);
}

test "test_repl_init_counters_zero" {
    // Verify: all counters start at zero
    const state = repl_init();
    try std.testing.expectEqual(@as(u32, 0), state.health_streak);
    try std.testing.expectEqual(@as(u64, 0), state.total_commands);
    try std.testing.expectEqual(@as(u64, 0), state.total_errors);
}

test "test_parse_command_help" {
    // Verify: "help" maps to ReplCommand.help
    var input = "help";
    const cmd = parse_command(input, 4);
    try std.testing.expectEqual(ReplCommand.help, cmd);
}

test "test_parse_command_quit" {
    // Verify: "quit" maps to ReplCommand.quit
    var input = "quit";
    const cmd = parse_command(input, 4);
    try std.testing.expectEqual(ReplCommand.quit, cmd);
}

test "test_parse_command_unknown_defaults_to_status" {
    // Verify: unknown commands default to status
    var input = "xyz";
    const cmd = parse_command(input, 3);
    try std.testing.expectEqual(ReplCommand.status, cmd);
}

test "test_register_plugin_increments_count" {
    // Verify: register_plugin adds plugin and increments count
    var state = repl_init();
    var plugin = ReplPlugin{
        .name = [_]u8{0} ** 64,
        .name_len = 4,
        .help_text = [_]u8{0} ** 256,
        .help_len = 0,
        .handler_id = 100,
        .ring_added = 48,
        .is_active = true,
    };
    _ = register_plugin(&state, plugin);
    try std.testing.expectEqual(@as(u8, 1), state.plugin_count);
}

test "test_register_plugin_max_limit" {
    // Verify: register_plugin does not exceed MAX_PLUGINS
    var state = repl_init();
    state.plugin_count = MAX_PLUGINS;
    var plugin = ReplPlugin{
        .name = [_]u8{0} ** 64,
        .name_len = 4,
        .help_text = [_]u8{0} ** 256,
        .help_len = 0,
        .handler_id = 999,
        .ring_added = 99,
        .is_active = true,
    };
    _ = register_plugin(&state, plugin);
    try std.testing.expectEqual(MAX_PLUGINS, state.plugin_count);
}

test "test_handle_quit_stops_loop" {
    // Verify: handle_quit sets is_running to false
    var state = repl_init();
    try std.testing.expect(state.is_running);
    const result = handle_quit(&state);
    try std.testing.expect(!state.is_running);
    try std.testing.expect(result.success);
}

test "test_dispatch_command_help_returns_clean" {
    // Verify: dispatching help returns clean toxicity
    var state = repl_init();
    var input = "help";
    const result = dispatch_command(&state, .help, input, 4);
    try std.testing.expect(result.success);
    try std.testing.expectEqual(@as(Trit, .pos), result.toxicity);
}

test "test_repl_eval_increments_total_commands" {
    // Verify: repl_eval increments total_commands counter
    var state = repl_init();
    var input = "help";
    _ = repl_eval(&state, input, 4);
    try std.testing.expectEqual(@as(u64, 1), state.total_commands);
}

// ============================================================================
// TDD - Invariants
// ============================================================================

invariant repl_command_enum_complete {
    // All 16 REPL commands are defined in the enum
    @compileAssert(@typeInfo(ReplCommand).Enum.fields.len == 16);
}

invariant max_history_positive {
    // MAX_HISTORY must be positive and reasonable
    @compileAssert(MAX_HISTORY > 0);
    @compileAssert(MAX_HISTORY <= 65535);
}

invariant max_plugins_positive {
    // MAX_PLUGINS must be positive
    @compileAssert(MAX_PLUGINS > 0);
    @compileAssert(MAX_PLUGINS <= 255);
}

invariant command_result_toxicity_is_trit {
    // CommandResult.toxicity is a valid Trit value
    @compileAssert(true);
}

invariant ring_delta_bounded {
    // ring_delta is in {-1, 0, +1}
    @compileAssert(true);
}

invariant session_history_count_bounded {
    // session count never exceeds MAX_HISTORY
    @compileAssert(MAX_HISTORY == 4096);
}

invariant repl_init_is_valid_state {
    // repl_init produces a state with is_running = true and zero counters
    @compileAssert(true);
}

invariant dispatch_covers_all_commands {
    // dispatch_command handles every ReplCommand variant
    @compileAssert(true);
}

// ============================================================================
// TDD - Benchmarks
// ============================================================================

bench "bench_repl_init_latency" {
    // Measure: cycles for repl_init
    // Target: < 1000 cycles (pure memory initialization)
    @setEvalBranchQuota(10000);
    var result : ReplState = undefined;
    for (0..1000) |_| {
        result = repl_init();
    }
    try std.testing.expect(result.is_running);
}

bench "bench_parse_command_latency" {
    // Measure: cycles for parse_command dispatch
    // Target: < 100 cycles (simple string match)
    @setEvalBranchQuota(10000);
    var cmd : ReplCommand = .status;
    var input = "help";
    for (0..1000) |_| {
        cmd = parse_command(input, 4);
    }
    try std.testing.expectEqual(ReplCommand.help, cmd);
}

bench "bench_dispatch_command_latency" {
    // Measure: cycles for dispatch_command routing
    // Target: < 200 cycles (switch dispatch)
    @setEvalBranchQuota(10000);
    var state = repl_init();
    var input = "status";
    for (0..1000) |_| {
        _ = dispatch_command(&state, .status, input, 6);
    }
    try std.testing.expect(state.is_running);
}

bench "bench_register_plugin_latency" {
    // Measure: cycles for register_plugin
    // Target: < 500 cycles (array write + increment)
    @setEvalBranchQuota(10000);
    var state = repl_init();
    var plugin = ReplPlugin{
        .name = [_]u8{0} ** 64,
        .name_len = 4,
        .help_text = [_]u8{0} ** 256,
        .help_len = 0,
        .handler_id = 1,
        .ring_added = 47,
        .is_active = true,
    };
    for (0..64) |_| {
        _ = register_plugin(&state, plugin);
    }
    try std.testing.expectEqual(MAX_PLUGINS, state.plugin_count);
}

; phi^2 + 1/phi^2 = 3 | TRINITY
