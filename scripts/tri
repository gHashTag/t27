#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
T27C="${TRI_T27C:-}"
if [[ -z "$T27C" ]]; then
  for p in "$ROOT/target/release/t27c" "$ROOT/target/debug/t27c" "$ROOT/bootstrap/target/release/t27c" "$ROOT/bootstrap/target/debug/t27c"; do
    [[ -x "$p" ]] && T27C="$p" && break
  done
fi
[[ -n "${T27C:-}" && -x "$T27C" ]] || {
  echo "tri: t27c not found. Run: cd bootstrap && cargo build --release" >&2
  exit 1
}
exec "$T27C" --repo-root "$ROOT" "$@"
