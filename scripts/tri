#!/usr/bin/env bash
# Trinity / t27 CLI shim — forwards to the bootstrap compiler (Rust binary `t27c`).
# Use from repo root: ./scripts/tri …
# Optional: ln -s "$(pwd)/scripts/tri" ~/.local/bin/tri
# Override: export TRI_T27C=/path/to/t27c
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

resolve_t27c() {
    if [[ -n "${TRI_T27C:-}" ]]; then
        echo "$TRI_T27C"
        return
    fi
    if [[ -x "$ROOT/bootstrap/target/release/t27c" ]]; then
        echo "$ROOT/bootstrap/target/release/t27c"
        return
    fi
    if [[ -x "$ROOT/bootstrap/target/debug/t27c" ]]; then
        echo "$ROOT/bootstrap/target/debug/t27c"
        return
    fi
    echo ""
}

T27C="$(resolve_t27c)"
if [[ -z "$T27C" ]]; then
    echo "tri: no compiler binary found. Build with: cd bootstrap && cargo build --release" >&2
    echo "tri: or set TRI_T27C to your t27c executable." >&2
    exit 1
fi

gen_dir_tree() {
    local backend_cmd="$1"
    local out_root="$2"
    local ext="$3"
    local dir="${4:?directory required}"
    dir="$(cd "$ROOT" && realpath "$dir" 2>/dev/null || echo "$ROOT/$dir")"
    [[ -d "$dir" ]] || {
        echo "tri: not a directory: $dir" >&2
        exit 1
    }
    local count=0
    while IFS= read -r -d '' f; do
        local rel=""
        if [[ "$f" == "$ROOT/specs/"* ]]; then
            rel="${f#"$ROOT/specs/"}"
        elif [[ "$f" == "$ROOT/compiler/"* ]]; then
            rel="compiler/${f#"$ROOT/compiler/"}"
        else
            rel="$(basename "$f")"
        fi
        rel="${rel%.t27}"
        local out="$ROOT/$out_root/${rel}.$ext"
        mkdir -p "$(dirname "$out")"
        case "$backend_cmd" in
            gen) "$T27C" gen "$f" >"$out" ;;
            gen-c) "$T27C" gen-c "$f" >"$out" ;;
            gen-verilog) "$T27C" gen-verilog "$f" >"$out" ;;
        esac
        count=$((count + 1))
    done < <(find "$dir" -type f -name '*.t27' -print0 | sort -z)
    echo "tri: wrote $count file(s) under $out_root/"
}

usage() {
    cat <<'EOF'
tri — Trinity / t27 command front-end (wraps bootstrap t27c)

Usage:
  tri parse <file.t27>
  tri gen-zig <file.t27>              # Zig to stdout
  tri gen-zig <dir>                   # all .t27 under dir → gen/zig/…
  tri gen-c <file.t27> | <dir>
  tri gen-verilog <file.t27> | <dir>
  tri compile … | compile-project … | compile-all …
  tri seal <file.t27> [--save | --verify]
  tri skill seal --hash <file.t27>    # → seal --save
  tri conformance <file.json>
  tri stats
  tri test                            # t27c suite (parse/gen/seal/fixed-point)
  tri validate-conformance [path]     # t27c validate-conformance
  tri validate-gen-headers            # t27c validate-gen-headers
  tri brain …                         # placeholder (see brain charter)

Environment: TRI_T27C=path/to/t27c
EOF
}

cmd="${1:-}"
[[ -z "$cmd" ]] && {
    usage
    exit 0
}
shift || true

case "$cmd" in
    help | -h | --help)
        usage
        exit 0
        ;;
    parse)
        exec "$T27C" parse "$@"
        ;;
    gen-zig)
        if [[ $# -eq 1 && -d "$1" ]]; then
            gen_dir_tree gen gen/zig zig "$1"
        else
            exec "$T27C" gen "$@"
        fi
        ;;
    gen-c)
        if [[ $# -eq 1 && -d "$1" ]]; then
            gen_dir_tree gen-c gen/c c "$1"
        else
            exec "$T27C" gen-c "$@"
        fi
        ;;
    gen-verilog)
        if [[ $# -eq 1 && -d "$1" ]]; then
            gen_dir_tree gen-verilog gen/verilog v "$1"
        else
            exec "$T27C" gen-verilog "$@"
        fi
        ;;
    gen)
        exec "$T27C" gen "$@"
        ;;
    compile)
        exec "$T27C" compile "$@"
        ;;
    compile-project)
        exec "$T27C" compile-project "$@"
        ;;
    compile-all)
        exec "$T27C" compile-all "$@"
        ;;
    seal)
        exec "$T27C" seal "$@"
        ;;
    skill)
        if [[ "${1:-}" == "seal" && "${2:-}" == "--hash" && -n "${3:-}" ]]; then
            exec "$T27C" seal "$3" --save
        fi
        echo "tri: unknown skill subcommand. Try: tri skill seal --hash <file.t27>" >&2
        exit 1
        ;;
    conformance)
        exec "$T27C" conformance "$@"
        ;;
    stats)
        exec "$T27C" stats "$@"
        ;;
    test)
        exec "$T27C" suite --repo-root "$ROOT"
        ;;
    validate-conformance)
        if [[ -n "${1:-}" ]]; then
            echo "tri: note: validate-conformance path filter not implemented; running full JSON scan." >&2
        fi
        exec "$T27C" validate-conformance --repo-root "$ROOT"
        ;;
    validate-gen-headers)
        exec "$T27C" validate-gen-headers --repo-root "$ROOT"
        ;;
    brain)
        echo "tri brain: not implemented in this repository yet." >&2
        echo "Planned: status, cycle, map, regions, coherence, connectivity, benchmark, evolve" >&2
        echo "See docs/TRINITY-BRAIN-NEUROANATOMY-TZ.md" >&2
        exit 2
        ;;
    git | verdict | experience | lint)
        echo "tri $cmd: not wired in scripts/tri — product/PHI LOOP CLI (see README)." >&2
        exit 2
        ;;
    *)
        echo "tri: unknown command: $cmd" >&2
        usage >&2
        exit 1
        ;;
esac
