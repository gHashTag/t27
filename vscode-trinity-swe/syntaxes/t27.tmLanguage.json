{
  "name": "T27",
  "scopeName": "source.t27",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#builtins"},
    {"include": "#keywords"},
    {"include": "#types"},
    {"include": "#constants"},
    {"include": "#numbers"},
    {"include": "#switch-expressions"},
    {"include": "#functions"},
    {"include": "#operators"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.t27",
          "match": ";.*$",
          "captures": {"0": {"name": "punctuation.definition.comment.t27"}}
        },
        {
          "name": "comment.line.double-slash.t27",
          "match": "//.*$",
          "captures": {"0": {"name": "punctuation.definition.comment.t27"}}}
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.t27",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {"0": {"name": "punctuation.definition.string.begin.t27"}},
          "endCaptures": {"0": {"name": "punctuation.definition.string.end.t27"}}
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.t27",
          "match": "\\b(if|else|switch|for|return|try|catch)\\b"
        },
        {
          "name": "keyword.declaration.t27",
          "match": "\\b(module|pub|const|var|fn|struct|enum|test|invariant|bench)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.t27",
          "match": "\\b(i8|u8|i16|u16|i32|u32|i64|u64|f16|f32|f64|bool|void|usize|isize)\\b"
        },
        {
          "name": "support.type.ternary.t27",
          "match": "\\b(Trit|PackedTrit|TernaryWord|Ternary|Triformat)\\b"
        },
        {
          "match": "(\\[)(\\d*)(\\])",
          "captures": {
            "1": {"name": "punctuation.definition.array.begin.t27"},
            "2": {"name": "constant.numeric.integer.t27"},
            "3": {"name": "punctuation.definition.array.end.t27"}
          }
        },
        {
          "match": "(\\[)(\\_)(\\])",
          "captures": {
            "1": {"name": "punctuation.definition.array.begin.t27"},
            "2": {"name": "variable.language.wildcard.t27"},
            "3": {"name": "punctuation.definition.array.end.t27"}
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.phi.t27",
          "match": "\\b(PHI|PHI_INV|PHI_SQ|TRINITY|GOLDEN_RATIO)\\b"
        },
        {
          "name": "constant.language.boolean.t27",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.trit.t27",
          "match": "\\.(pos|neg|neu|zero)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.t27",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.t27",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.t27",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.negative.t27",
          "match": "(?<=\\s|^)-(\\d+\\.?\\d*)\\b",
          "captures": {
            "1": {"name": "constant.numeric.integer.t27"}
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.t27",
          "match": "@(as|intCast|intFromEnum|enumFromInt|compileAssert|setEvalBranchQuota|import|embedFile|typeName|sizeOf|alignOf|offsetOf|hasDecl|hasField|cDefine|cInclude|cUndef)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.t27",
          "match": "(?x)(fn)\\s+(\\w+)",
          "captures": {
            "1": {"name": "keyword.declaration.function.t27"},
            "2": {"name": "entity.name.function.t27"}
          }
        },
        {
          "name": "meta.function.call.t27",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {"name": "entity.name.function.call.t27"}
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.range.t27",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.power.t27",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.comparison.t27",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.augmented.t27",
          "match": "\\+=|\\-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>="
        },
        {
          "name": "keyword.operator.assignment.t27",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.t27",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pointer.t27",
          "match": "\\*|&"
        },
        {
          "name": "keyword.operator.bitwise.t27",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.logical.t27",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.t27",
          "match": "\\+|\\-|\\*|/%"
        }
      ]
    },
    "switch-expressions": {
      "patterns": [
        {
          "match": "(\\s*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(\\s*)(=>)",
          "captures": {
            "2": {"name": "punctuation.accessor.dot.t27"},
            "3": {"name": "constant.other.enum-member.t27"},
            "5": {"name": "keyword.operator.arrow.t27"}
          }
        }
      ]
    },
    "wildcard": {
      "patterns": [
        {
          "name": "variable.language.wildcard.t27",
          "match": "\\b_\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.t27",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.t27",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.t27",
          "match": ";"
        }
      ]
    }
  }
}
