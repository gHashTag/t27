; runtime.t27 — Zig Runtime Code Generation
; Generates Zig backend from compiler/runtime/*.t27 specifications
; φ² + 1/φ² = 3 | TRINITY

.use compiler::runtime::commands
.use compiler::runtime::validation

; ═════════════════════════════════════════════════════════════════════
; Zig Runtime Generation
; ═════════════════════════════════════════════════════════════════════

; Generate main.zig entry point
fn generate_main() -> string {
    return "// This file is generated from compiler/runtime/runtime.t27\n" +
           "// DO NOT EDIT - Changes will be overwritten on next tri gen\n" +
           "// Generated at: " + get_current_timestamp() + "\n" +
           "// Source spec: compiler/runtime/runtime.t27\n" +
           "\n" +
           "const std = @import(\"std\");\n" +
           "const commands = @import(\"commands.zig\");\n" +
           "\n" +
           "pub fn main() !u8 {\n" +
           "    const allocator = std.heap.page_allocator;\n" +
           "    const args = try std.process.argsAlloc(allocator);\n" +
           "    defer std.process.argsFree(allocator, args);\n" +
           "\n" +
           "    if (args.len < 2) {\n" +
           "        try commands.help(\"\");\n" +
           "        return 0;\n" +
           "    }\n" +
           "\n" +
           "    const command = args[1];\n" +
           "    const command_args = args[2..];\n" +
           "\n" +
           "    return dispatch_command(command, command_args);\n" +
           "}\n" +
           "\n" +
           "fn dispatch_command(command: []const u8, args: [][]const u8) !u8 {\n" +
           "    if (std.mem.eql(u8, command, \"spec\")) {\n" +
           "        return commands.spec_dispatch(args);\n" +
           "    } else if (std.mem.eql(u8, command, \"gen\")) {\n" +
           "        return commands.gen_dispatch(args);\n" +
           "    } else if (std.mem.eql(u8, command, \"git\")) {\n" +
           "        return commands.git_dispatch(args);\n" +
           "    } else if (std.mem.eql(u8, command, \"lint\")) {\n" +
           "        return commands.lint_dispatch(args);\n" +
           "    } else if (std.mem.eql(u8, command, \"skill\")) {\n" +
           "        return commands.skill_dispatch(args);\n" +
           "    } else if (std.mem.eql(u8, command, \"help\")) {\n" +
           "        try commands.help(if (args.len > 0) args[0] else \"\");\n" +
           "        return 0;\n" +
           "    } else {\n" +
           "        std.debug.print(\"Unknown command: {s}\\n\", .{command});\n" +
           "        try commands.help(\"\");\n" +
           "        return 1;\n" +
           "    }\n" +
           "}\n";
}

; Generate commands.zig
fn generate_commands_module() -> string {
    return "// This file is generated from compiler/runtime/commands.t27\n" +
           "// DO NOT EDIT - Changes will be overwritten on next tri gen\n" +
           "// Generated at: " + get_current_timestamp() + "\n" +
           "// Source spec: compiler/runtime/commands.t27\n" +
           "\n" +
           "const std = @import(\"std\");\n" +
           "const validation = @import(\"validation.zig\");\n" +
           "\n" +
           "pub fn spec_dispatch(args: [][]const u8) !u8 {\n" +
           "    if (args.len < 1) {\n" +
           "        try help(\"spec\");\n" +
           "        return 0;\n" +
           "    }\n" +
           "\n" +
           "    const subcommand = args[0];\n" +
           "\n" +
           "    if (std.mem.eql(u8, subcommand, \"create\")) {\n" +
           "        if (args.len < 2) {\n" +
           "            std.debug.print(\"ERROR: spec name required\\n\", .{});\n" +
           "            return 1;\n" +
           "        }\n" +
           "        const name = args[1];\n" +
           "        const kind = if (args.len > 2) args[2] else \"feature\";\n" +
           "        return spec_create(name, kind);\n" +
           "    } else if (std.mem.eql(u8, subcommand, \"validate\")) {\n" +
           "        if (args.len < 2) {\n" +
           "            std.debug.print(\"ERROR: spec path required\\n\", .{});\n" +
           "            return 1;\n" +
           "        }\n" +
           "        return spec_validate(args[1]);\n" +
           "    } else if (std.mem.eql(u8, subcommand, \"list\")) {\n" +
           "        return spec_list();\n" +
           "    } else {\n" +
           "        try help(\"spec\");\n" +
           "        return 1;\n" +
           "    }\n" +
           "}\n" +
           "\n" +
           "pub fn gen_dispatch(args: [][]const u8) !u8 {\n" +
           "    if (args.len == 0 or std.mem.eql(u8, args[0], \"--all\")) {\n" +
           "        const backend = if (args.len > 1) args[1] else \"zig\";\n" +
           "        return gen_all(backend);\n" +
           "    } else {\n" +
           "        const spec_path = args[0];\n" +
           "        const backend = if (args.len > 1) args[1] else \"zig\";\n" +
           "        return gen_spec(spec_path, backend, false);\n" +
           "    }\n" +
           "}\n" +
           "\n" +
           "pub fn git_dispatch(args: [][]const u8) !u8 {\n" +
           "    // Git command dispatch\n" +
           "    const allocator = std.heap.page_allocator;\n" +
           "\n" +
           "    if (args.len == 0 or std.mem.eql(u8, args[0], \"status\")) {\n" +
           "        return git_status_with_skill();\n" +
           "    } else if (std.mem.eql(u8, args[0], \"commit\")) {\n" +
           "        const all = parse_bool_flag(args, \"--all\");\n" +
           "        const message = parse_string_flag(args, \"-m\");\n" +
           "        const mode = parse_string_flag(args, \"--mode\") orelse \"normal\";\n" +
           "        return git_commit(all, message, mode);\n" +
           "    } else if (std.mem.eql(u8, args[0], \"push\")) {\n" +
           "        const mode = parse_string_flag(args, \"--mode\") orelse \"normal\";\n" +
           "        return git_push(\"\", \"\", mode);\n" +
           "    }\n" +
           "\n" +
           "    return 0;\n" +
           "}\n" +
           "\n" +
           "pub fn lint_dispatch(args: [][]const u8) !u8 {\n" +
           "    const strict = parse_bool_flag(args, \"--strict\");\n" +
           "\n" +
           "    if (args.len == 0 or std.mem.eql(u8, args[0], \"--all\")) {\n" +
           "        return lint_all(strict);\n" +
           "    } else {\n" +
           "        return lint_file(args[0], strict);\n" +
           "    }\n" +
           "}\n" +
           "\n" +
           "pub fn skill_dispatch(args: [][]const u8) !u8 {\n" +
           "    if (args.len == 0) {\n" +
           "        return skill_status();\n" +
           "    }\n" +
           "\n" +
           "    const subcommand = args[0];\n" +
           "\n" +
           "    if (std.mem.eql(u8, subcommand, \"begin\")) {\n" +
           "        const issue = parse_string_flag(args, \"--issue\") orelse \"\";\n" +
           "        const kind = parse_string_flag(args, \"--kind\") orelse \"feature\";\n" +
           "        return skill_begin(issue, kind);\n" +
           "    } else if (std.mem.eql(u8, subcommand, \"seal\")) {\n" +
           "        return skill_seal();\n" +
           "    } else if (std.mem.eql(u8, subcommand, \"status\")) {\n" +
           "        return skill_status();\n" +
           "    }\n" +
           "\n" +
           "    return 0;\n" +
           "}\n" +
           "\n" +
           "// Helper functions\n" +
           "fn parse_bool_flag(args: [][]const u8, flag: []const u8) bool {\n" +
           "    for (args) |arg| {\n" +
           "        if (std.mem.eql(u8, arg, flag)) return true;\n" +
           "    }\n" +
           "    return false;\n" +
           "}\n" +
           "\n" +
           "fn parse_string_flag(args: [][]const u8, flag: []const u8) ?[]const u8 {\n" +
           "    var i: usize = 0;\n" +
           "    while (i < args.len - 1) : (i += 1) {\n" +
           "        if (std.mem.eql(u8, args[i], flag)) {\n" +
           "            return args[i + 1];\n" +
           "        }\n" +
           "    }\n" +
           "    return null;\n" +
           "}\n";
}

; Generate validation.zig
fn generate_validation_module() -> string {
    return "// This file is generated from compiler/runtime/validation.t27\n" +
           "// DO NOT EDIT - Changes will be overwritten on next tri gen\n" +
           "// Generated at: " + get_current_timestamp() + "\n" +
           "// Source spec: compiler/runtime/validation.t27\n" +
           "\n" +
           "const std = @import(\"std\");\n" +
           "\n" +
           "pub const ValidationResult = struct {\n" +
           "    valid: bool,\n" +
           "    error_msg: []const u8,\n" +
           "    hint: []const u8,\n" +
           "};\n" +
           "\n" +
           "pub fn validate_tdd_contract(spec_path: []const u8) !ValidationResult {\n" +
           "    const content = try std.fs.cwd().readFileAlloc(\n" +
           "        std.heap.page_allocator,\n" +
           "        spec_path,\n" +
           "        1024 * 1024,\n" +
           "    );\n" +
           "    defer std.heap.page_allocator.free(content);\n" +
           "\n" +
           "    const has_test = std.mem.indexOf(u8, content, \".test\") != null;\n" +
           "    const has_invariant = std.mem.indexOf(u8, content, \".invariant\") != null;\n" +
           "\n" +
           "    if (!has_test and !has_invariant) {\n" +
           "        return ValidationResult{\n" +
           "            .valid = false,\n" +
           "            .error_msg = \"TDD contract violated: spec must contain at least one 'test' or 'invariant' block\",\n" +
           "            .hint = \"See: docs/TDD-CONTRACT.md\",\n" +
           "        };\n" +
           "    }\n" +
           "\n" +
           "    return ValidationResult{\n" +
           "        .valid = true,\n" +
           "        .error_msg = \"\",\n" +
           "        .hint = \"\",\n" +
           "    };\n" +
           "}\n" +
           "\n" +
           "pub fn validate_language_policy(spec_path: []const u8) !ValidationResult {\n" +
           "    // Check if path is docs/ (Cyrillic allowed in docs)\n" +
           "    if (std.mem.startsWith(u8, spec_path, \"docs/\")) {\n" +
           "        return ValidationResult{ .valid = true, .error_msg = \"\", .hint = \"\" };\n" +
           "    }\n" +
           "\n" +
           "    const content = try std.fs.cwd().readFileAlloc(\n" +
           "        std.heap.page_allocator,\n" +
           "        spec_path,\n" +
           "        1024 * 1024,\n" +
           "    );\n" +
           "    defer std.heap.page_allocator.free(content);\n" +
           "\n" +
           "    // Check for Cyrillic characters (U+0400–U+04FF)\n" +
           "    for (content) |c| {\n" +
           "        if (c >= 0x0400 and c <= 0x04FF) {\n" +
           "            return ValidationResult{\n" +
           "                .valid = false,\n" +
           "                .error_msg = \"Language policy violated: source file contains Cyrillic characters\",\n" +
           "                .hint = \"Source files must be ASCII-only. See: ADR-004-language-policy.md\",\n" +
           "            };\n" +
           "        }\n" +
           "    }\n" +
           "\n" +
           "    return ValidationResult{\n" +
           "        .valid = true,\n" +
           "        .error_msg = \"\",\n" +
           "        .hint = \"\",\n" +
           "    };\n" +
           "}\n" +
           "\n" +
           "pub fn validate_generated_header(zig_path: []const u8) !ValidationResult {\n" +
           "    const file = try std.fs.cwd().openFile(zig_path, .{});\n" +
           "    defer file.close();\n" +
           "\n" +
           "    const reader = file.reader();\n" +
           "    var line_buffer: [256]u8 = undefined;\n" +
           "\n" +
           "    // Check first line for generated header\n" +
           "    const line1 = try reader.readUntilDelimiterOrEof(&line_buffer, '\\n') orelse \"\";\n" +
           "    if (!std.mem.indexOf(u8, line1, \"This file is generated from\") != null) {\n" +
           "        return ValidationResult{\n" +
           "            .valid = false,\n" +
           "            .error_msg = \"Zig file lacks generated header\",\n" +
           "            .hint = \"Write .t27 spec first, then run 'tri gen'\",\n" +
           "        };\n" +
           "    }\n" +
           "\n" +
           "    // Check second line for DO NOT EDIT\n" +
           "    const line2 = try reader.readUntilDelimiterOrEof(&line_buffer, '\\n') orelse \"\";\n" +
           "    if (!std.mem.indexOf(u8, line2, \"DO NOT EDIT\") != null) {\n" +
           "        return ValidationResult{\n" +
           "            .valid = false,\n" +
           "            .error_msg = \"Zig file header missing 'DO NOT EDIT' warning\",\n" +
           "            .hint = \"Generated files must not be edited\",\n" +
           "        };\n" +
           "    }\n" +
           "\n" +
           "    return ValidationResult{\n" +
           "        .valid = true,\n" +
           "        .error_msg = \"\",\n" +
           "        .hint = \"\",\n" +
           "    };\n" +
           "}\n";
}

; Generate src/tri/main.zig (entry point)
fn generate_main_zig() -> string {
    return generate_main();
}

; Generate src/tri/commands.zig
fn generate_commands_zig() -> string {
    return generate_commands_module();
}

; Generate src/tri/validation.zig
fn generate_validation_zig() -> string {
    return generate_validation_module();
}

; ═════════════════════════════════════════════════════════════════════
; Code generation entry point
; ═════════════════════════════════════════════════════════════════════

; Generate all Zig runtime files
fn generate_runtime_zig() -> i32 {
    let base_dir = "src/tri/";
    create_dir_if_not_exists(base_dir);

    ; Generate main.zig
    write_file(base_dir + "main.zig", generate_main_zig());

    ; Generate commands.zig
    write_file(base_dir + "commands.zig", generate_commands_zig());

    ; Generate validation.zig
    write_file(base_dir + "validation.zig", generate_validation_zig());

    print("Generated Zig runtime:");
    print("  " + base_dir + "main.zig");
    print("  " + base_dir + "commands.zig");
    print("  " + base_dir + "validation.zig");

    return 0;
}

; ═══════════════════════════════════════════════════════════════════════════════════════════════════════
; TDD-Inside-Spec: Tests and Invariants for Runtime Code Generation
; ═══════════════════════════════════════════════════════════════════════════════════════════════════════

test generate_main_contains_header
    given main_zig = generate_main()
    then main_zig.contains("This file is generated from compiler/runtime/runtime.t27")

test generate_main_contains_dispatch_function
    given main_zig = generate_main()
    then main_zig.contains("fn dispatch_command")

test generate_main_includes_commands_import
    given main_zig = generate_main()
    then main_zig.contains("const commands = @import")

test generate_commands_module_contains_spec_dispatch
    given commands_zig = generate_commands_module()
    then commands_zig.contains("pub fn spec_dispatch")

test generate_commands_module_contains_validation_import
    given commands_zig = generate_commands_module()
    then commands_zig.contains("const validation = @import")

test generate_validation_module_contains_tdd_contract_check
    given validation_zig = generate_validation_module()
    then validation_zig.contains("validate_tdd_contract")

test generate_validation_module_contains_language_policy_check
    given validation_zig = generate_validation_module()
    then validation_zig.contains("validate_language_policy")

test generate_validation_module_contains_header_check
    given validation_zig = generate_validation_module()
    then validation_zig.contains("validate_generated_header")

test generate_runtime_zig_returns_zero_on_success
    when result = generate_runtime_zig()
    then result == 0

invariant generate_main_always_includes_header
    ; generate_main always includes generated header
    assert true

invariant generate_main_always_has_main_function
    ; generate_main always exports pub fn main()
    assert true

invariant generate_commands_module_always_has_dispatch_functions
    ; generate_commands_module generates all dispatch functions
    assert true

invariant generate_validation_module_defines_validation_result
    ; generate_validation_module defines ValidationResult struct
    assert true

invariant all_generated_files_have_do_not_edit_header
    ; All generated files contain "DO NOT EDIT" warning
    assert true

bench generate_main_latency
    measure: nanoseconds to generate_main()
    target: < 10us

bench generate_commands_module_latency
    measure: nanoseconds to generate_commands_module()
    target: < 50us

bench generate_validation_module_latency
    measure: nanoseconds to generate_validation_module()
    target: < 20us

bench generate_runtime_zig_latency
    measure: nanoseconds to generate_runtime_zig()
    target: < 100us
