        // TDD-Inside-Spec blocks (assembly-style)
        Test = 50,
        Invariant = 51,
        Bench = 52,
        TestCase = 53,
        InvariantDecl = 54,
        BenchDecl = 55,

        // TDD-Inside-Spec high-level structures (spec-style)
        SpecDecl = 60,           // spec keyword/module header
        RuleBlock = 61,          // rule block
        GivenClause = 62,        // given clause in test
        WhenClause = 63,         // when clause in test
        ThenClause = 64,         // then clause in test
        AndClause = 65,          // and clause in test
        ExpectClause = 66,       // expect clause in rule
        AssertStmt = 67,         // assert statement in invariant
