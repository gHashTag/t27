; git.t27 — Git Integration with Tri Skill Workflow (ADR-002)
; Commands for git operations with skill validation and issue binding

; tri git commit [--all] [-m "msg"] [--mode strict|normal|local]
fn git_commit(all : bool, message : string, mode : string) -> i32 {
    let registry_path = ".trinity/skills/registry.json";

    ; Check if registry exists
    if !file_exists(registry_path) {
        error("ERROR: no active or sealed skill; NO-COMMIT-WITHOUT-ISSUE violated");
        error("Run 'tri skill begin --issue N' first to create a skill");
        return 1;
    }

    ; Read registry
    let registry_content = read_file(registry_path);
    if registry_content == null {
        error("ERROR: failed to read skill registry");
        return 1;
    }

    ; Parse registry and find active or last sealed skill
    let skill = find_active_or_sealed_skill(registry_content);

    if skill == null {
        error("ERROR: no active or sealed skill; NO-COMMIT-WITHOUT-ISSUE violated");
        error("Run 'tri skill begin --issue N' first to create a skill");
        return 1;
    }

    ; Check issue-binding
    if !skill.has("issue") {
        error("ERROR: skill has no bound issue");
        error("Run 'tri skill begin --issue N' first to bind an issue");
        return 1;
    }

    let issue_id = skill.get("issue");

    ; Check verdict for sealed skills
    if skill.get("status") == "sealed" and skill.has("verdict") {
        let verdict = skill.get("verdict");
        if verdict == "TOXIC" {
            error("ERROR: cannot commit toxic skill; fix or supersede");
            error("Run 'tri experience save' to address toxic verdict");
            return 1;
        }
    }

    ; Build commit message
    let commit_msg = message;
    let skill_id = skill.get("id");

    if commit_msg == "" {
        ; Generate auto-summary from git status
        let status = git_status();
        commit_msg = "skill:" + skill_id + " issue:" + issue_id + " " + summarize_status(status);
    } else {
        ; Check if message has issue: prefix
        if !commit_msg.contains("issue:" + issue_id) {
            commit_msg = commit_msg + " issue:" + issue_id;
        }
    }

    ; In strict mode, add metadata
    if mode == "strict" and skill.get("status") == "sealed" {
        let seal_hash = skill.get("seal_hash");
        if seal_hash != "" {
            commit_msg = commit_msg + " seal:" + seal_hash;
        }
    }

    ; Stage files
    if all {
        let add_result = git_add_all();
        if add_result != 0 {
            return add_result;
        }
    }

    ; Create commit
    let commit_result = git_commit_message(commit_msg);
    if commit_result != 0 {
        ; Check if it was a git error vs policy error
        if commit_result == 2 {
            error("Git error: commit failed");
        }
        return commit_result;
    }

    ; Get commit hash
    let commit_hash = git_get_head_hash();

    ; Update registry with commit hash
    let updated_registry = update_registry_commit(registry_content, skill_id, commit_hash);
    write_file(registry_path, updated_registry);

    print("Committed: " + commit_hash.substring(0, 7));
    print("  Cell: " + skill_id);
    print("  Issue: " + issue_id);

    if mode == "strict" and skill.get("status") == "sealed" {
        print("  Seal: " + skill.get("seal_hash"));
        print("");
        print("NOTE: In strict mode, you must run 'tri git push' after committing");
    }

    return 0;
}

; tri git push [<remote> <branch>] [--mode strict|normal|local]
fn git_push(remote : string, branch : string, mode : string) -> i32 {
    let registry_path = ".trinity/skills/registry.json";

    ; Check if registry exists
    if !file_exists(registry_path) {
        error("ERROR: cannot push; skill not sealed (tri skill seal required)");
        return 1;
    }

    ; Read registry
    let registry_content = read_file(registry_path);
    if registry_content == null {
        error("ERROR: failed to read skill registry");
        return 1;
    }

    ; Find last sealed skill
    let skill = find_last_sealed_skill(registry_content);

    if skill == null {
        error("ERROR: cannot push; skill not sealed (tri skill seal required)");
        error("Run 'tri skill seal' to seal the current skill");
        return 1;
    }

    ; Check verdict
    if skill.has("verdict") {
        let verdict = skill.get("verdict");
        if verdict == "TOXIC" {
            error("ERROR: cannot push toxic skill");
            return 1;
        }
    }

    ; Check artifacts by Policy Matrix
    let kind = skill.get("kind");
    let artifacts = if skill.has("artifacts") { skill.get("artifacts") } else { "" };

    if kind == "recovery" {
        ; Require minimum 3 checkpoints + spec and docs
        let checkpoints = count_checkpoints(artifacts);
        let has_spec = artifacts.contains("spec");
        let has_docs = artifacts.contains("docs");

        if checkpoints < 3 or !has_spec or !has_docs {
            error("ERROR: policy gate failed for skill kind " + kind);
            error("Recovery skills require:");
            error("  - At least 3 checkpoints");
            error("  - Spec changes");
            error("  - Docs changes");
            return 1;
        }
    } else if kind == "hotfix" {
        ; Require >=1 checkpoint and only fix-only areas
        let checkpoints = count_checkpoints(artifacts);
        if checkpoints < 1 {
            error("ERROR: policy gate failed for skill kind " + kind);
            error("Hotfix skills require at least 1 checkpoint");
            return 1;
        }
    }

    ; Check remote in strict mode
    if mode == "strict" {
        let default_remote = if remote == "" { "origin" } else { remote };
        let remote_url = git_get_remote_url(default_remote);

        if !remote_url.contains("github.com/gHashTag/t27") {
            error("ERROR: forbidden remote; expected github.com/gHashTag/t27");
            error("Current remote: " + remote_url);
            return 1;
        }
    }

    ; Determine target
    let push_remote = if remote == "" { "origin" } else { remote };
    let push_branch = if branch == "" { git_get_current_branch() } else { branch };

    ; Execute push
    let push_result = git_push_remote(push_remote, push_branch);

    if push_result != 0 {
        if push_result == 1 {
            error("Push failed: gate violations");
        } else if push_result == 2 {
            error("Push failed: git error (reject, network, etc.)");
        }
        return push_result;
    }

    ; Update registry with push status
    let skill_id = skill.get("id");
    let timestamp = get_current_timestamp();
    let updated_registry = update_registry_push(registry_content, skill_id, true, timestamp);
    write_file(registry_path, updated_registry);

    print("Pushed to " + push_remote + "/" + push_branch);
    print("  Cell: " + skill_id);
    print("  Pushed at: " + timestamp);

    return 0;
}

; tri git status — Show git status with skill info
fn git_status_with_skill() -> i32 {
    let registry_path = ".trinity/skills/registry.json";

    ; Show git status
    let status = git_status();
    print("Git status:");
    print(status);
    print("");

    ; Show skill info if available
    if file_exists(registry_path) {
        let registry_content = read_file(registry_path);
        let skill = find_active_or_sealed_skill(registry_content);

        if skill != null {
            print("Current skill:");
            print("  ID: " + skill.get("id"));
            print("  Status: " + skill.get("status"));
            if skill.has("issue") {
                print("  Issue: " + skill.get("issue"));
            }
            if skill.has("verdict") {
                print("  Verdict: " + skill.get("verdict"));
            }
        } else {
            print("No active or sealed skill found");
        }
    } else {
        print("No skill registry found");
    }

    return 0;
}

; ═════════════════════════════════════════════════════════════════════
; Helper functions
; ═════════════════════════════════════════════════════════════════════

; Find active or last sealed skill from registry
fn find_active_or_sealed_skill(registry_json : string) -> map<string, string>? {
    let registry = parse_json(registry_json);

    ; First look for active skill
    for skill in registry.get("skills") {
        if skill.get("status") == "active" {
            return skill;
        }
    }

    ; Then look for last sealed skill on current branch
    let current_branch = git_get_current_branch();
    let last_sealed = null;

    for skill in registry.get("skills") {
        if skill.get("status") == "sealed" and skill.get("branch") == current_branch {
            let timestamp = skill.get("timestamp");
            if last_sealed == null or timestamp > last_sealed.get("timestamp") {
                last_sealed = skill;
            }
        }
    }

    return last_sealed;
}

; Find last sealed skill from registry
fn find_last_sealed_skill(registry_json : string) -> map<string, string>? {
    let registry = parse_json(registry_json);
    let last_sealed = null;

    for skill in registry.get("skills") {
        if skill.get("status") == "sealed" {
            let timestamp = skill.get("timestamp");
            if last_sealed == null or timestamp > last_sealed.get("timestamp") {
                last_sealed = skill;
            }
        }
    }

    return last_sealed;
}

; Update registry with commit hash
fn update_registry_commit(registry_json : string, skill_id : string, commit_hash : string) -> string {
    let registry = parse_json(registry_json);

    for skill in registry.get("skills") {
        if skill.get("id") == skill_id {
            skill.put("commit", commit_hash);
            skill.put("commit_at", get_current_timestamp());
            break;
        }
    }

    return serialize_json(registry);
}

; Update registry with push status
fn update_registry_push(registry_json : string, skill_id : string, pushed : bool, timestamp : string) -> string {
    let registry = parse_json(registry_json);

    for skill in registry.get("skills") {
        if skill.get("id") == skill_id {
            skill.put("pushed", if pushed { "true" } else { "false" });
            skill.put("pushed_at", timestamp);
            break;
        }
    }

    return serialize_json(registry);
}

; Summarize git status
fn summarize_status(status : string) -> string {
    ; Extract modified/added/deleted files count
    let modified = status.count("modified:");
    let added = status.count("new file:");
    let deleted = status.count("deleted:");

    let parts = [];
    if modified > 0 {
        parts.push(string.from_int(modified) + " modified");
    }
    if added > 0 {
        parts.push(string.from_int(added) + " added");
    }
    if deleted > 0 {
        parts.push(string.from_int(deleted) + " deleted");
    }

    if parts.len() == 0 {
        return "no changes";
    }

    return parts.join(", ");
}

; Count checkpoints in artifacts
fn count_checkpoints(artifacts : string) -> i32 {
    return artifacts.count("checkpoint");
}

; Get current timestamp
fn get_current_timestamp() -> string {
    ; Returns ISO 8601 timestamp
    return "2026-04-04T00:00:00Z";  // Placeholder
}

; ═══════════════════════════════════════════════════════════════════════════════════════════════════════
; TDD-Inside-Spec: Tests and Invariants for Git Integration
; ═══════════════════════════════════════════════════════════════════════════════════════════════════════

test git_commit_requires_registry
    given registry_exists = false
    when result = git_commit(all=false, message="test", mode="normal")
    then result == 1

test git_commit_requires_issue_binding
    given registry_exists = true
    and skill_has_issue = false
    when result = git_commit(all=false, message="test", mode="normal")
    then result == 1

test git_commit_rejects_toxic_verdict
    given skill_status = "sealed"
    and skill_verdict = "TOXIC"
    when result = git_commit(all=false, message="test", mode="normal")
    then result == 1

test git_commit_accepts_not_toxic_verdict
    given skill_status = "sealed"
    and skill_verdict = "NOT TOXIC"
    when result = git_commit(all=false, message="test", mode="normal")
    then result == 0

test git_push_requires_sealed_skill
    given skill_status = "active"
    when result = git_push(remote="", branch="", mode="normal")
    then result == 1

test git_push_rejects_toxic_skill
    given skill_status = "sealed"
    and skill_verdict = "TOXIC"
    when result = git_push(remote="", branch="", mode="normal")
    then result == 1

test git_push_recovery_requires_3_checkpoints
    given skill_kind = "recovery"
    and skill_checkpoints = 2
    when result = git_push(remote="", branch="", mode="normal")
    then result == 1

test git_push_hotfix_requires_1_checkpoint
    given skill_kind = "hotfix"
    and skill_checkpoints = 0
    when result = git_push(remote="", branch="", mode="normal")
    then result == 1

test git_push_strict_validates_remote
    given mode = "strict"
    and remote_url = "https://gitlab.com/other/repo"
    when result = git_push(remote="origin", branch="main", mode=mode)
    then result == 1

test git_commit_auto_adds_issue_to_message
    given skill_issue = "123"
    and original_msg = "fix bug"
    when result = git_commit(all=false, message=original_msg, mode="normal")
    then result == 0

test summarize_status_no_changes
    given status = "On branch main\nnothing to commit"
    when summary = summarize_status(status)
    then summary == "no changes"

test summarize_status_with_changes
    given status = "modified: file1.t27\nnew file: file2.t27"
    when summary = summarize_status(status)
    then summary.contains("modified") and summary.contains("added")

test count_checkpoints_returns_count
    given artifacts = "checkpoint1, checkpoint2, spec, docs"
    when count = count_checkpoints(artifacts)
    then count == 2

test count_checkpoints_zero
    given artifacts = "spec, docs"
    when count = count_checkpoints(artifacts)
    then count == 0

test get_current_timestamp_format
    given timestamp = get_current_timestamp()
    then timestamp.contains("T") and timestamp.contains("Z")

test git_status_with_skill_shows_skill_info
    given registry_exists = true
    and skill_id = "skill-001"
    and skill_status = "active"
    when result = git_status_with_skill()
    then result == 0

invariant git_commit_returns_zero_on_success
    ; Successful commit returns 0
    assert true

invariant git_commit_returns_nonzero_on_failure
    ; Failed commit returns non-zero
    assert true

invariant git_push_returns_zero_on_success
    ; Successful push returns 0
    assert true

invariant git_push_returns_nonzero_on_failure
    ; Failed push returns non-zero
    assert true

invariant git_status_with_skill_always_succeeds
    ; git status command always succeeds
    assert true

invariant summarize_status_never_null
    ; Summary always returns a string
    assert true

invariant count_checkpoints_never_negative
    ; Checkpoint count is always >= 0
    assert true

invariant recovery_skill_requires_min_3_checkpoints
    ; Recovery skill policy: minimum 3 checkpoints
    assert true

invariant hotfix_skill_requires_min_1_checkpoint
    ; Hotfix skill policy: minimum 1 checkpoint
    assert true

invariant strict_mode_validates_remote
    ; Strict mode requires expected remote URL
    assert true

bench git_commit_latency
    measure: nanoseconds to git_commit(all=false, message="test", mode="normal")
    target: < 500ms

bench git_push_latency
    measure: nanoseconds to git_push(remote="", branch="", mode="normal")
    target: < 1000ms

bench git_status_with_skill_latency
    measure: nanoseconds to git_status_with_skill()
    target: < 100ms

bench find_active_or_sealed_skill_latency
    measure: nanoseconds to find_active_or_sealed_skill(registry_json)
    target: < 10ms

bench update_registry_commit_latency
    measure: nanoseconds to update_registry_commit(registry_json, "skill-001", "abc123")
    target: < 5ms
