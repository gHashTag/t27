bench "bench_alloc_latency_cycles" {
    // Measure: cycles for runtime_alloc
    // Target: < 10 cycles for bump allocation
}

bench "test_channel_throughput_ops_per_sec" {
    // Measure: channel operations per second
    // Target: > 1M send/recv ops/sec on empty channels
}

bench "test_thread_context_switch_cycles" {
    // Measure: cycles for thread_yield and reschedule
    // Target: < 100 cycles for thread switch
}
