# Precision Routing Policy (Φ1) — Declarative T27 Format
# Version: 0.1.0
# Source: AI Consensus Analysis (GPT-5.4, Claude Opus 4.7, Gemini 3.1)

# ==============================================================================
# POLICY RULES
# ==============================================================================

# Rule 1: HIGH sensitivity layers MUST use GF16
rule "high_sensitivity_gf16" {
    when: layer.sensitivity == "HIGH"
    then: assign("GF16")
    reason: "HIGH sensitivity requires full floating-point precision for f32 parity"
}

# Rule 2: LOW sensitivity layers prefer Ternary
rule "low_sensitivity_ternary" {
    when: layer.sensitivity == "LOW" && dsp.available >= 0
    then: assign("Ternary158")
    reason: "LOW sensitivity allows quantization with zero DSP cost"
}

# Rule 3: MEDIUM sensitivity layers use GF16 if DSP available
rule "medium_sensitivity_gf16" {
    when: layer.sensitivity == "MEDIUM" && dsp.available >= 16
    then: assign("GF16")
    reason: "MEDIUM sensitivity with available DSP budget -> GF16"
}

# Rule 4: MEDIUM sensitivity fallback to Ternary
rule "medium_sensitivity_ternary" {
    when: layer.sensitivity == "MEDIUM" && dsp.available < 16
    then: assign("Ternary158")
    reason: "MEDIUM sensitivity, DSP constrained -> Ternary with STE"
}

# ==============================================================================
# LAYER-SPECIFIC OVERRIDES
# ==============================================================================

# Embedding: Always GF16 (representation learning critical)
override "embedding" {
    layer_type: "Embedding"
    precision: "GF16"
    reason: "Embedding requires full precision for representation learning"
}

# Attention (QKV, proj): Always GF16 (attention fragility)
override "attention" {
    layer_type: "Attention"
    precision: "GF16"
    reason: "Attention mechanisms are highly sensitive to quantization error"
}

# Output head: Always GF16 (final logits precision)
override "output" {
    layer_type: "OutputHead"
    precision: "GF16"
    reason: "Output layer requires precise logits for classification"
}

# FFN gate/up: Ternary (bulk quantized)
override "ffn_bulk" {
    layer_type: "Dense"
    name_contains: ["gate", "up"]
    precision: "Ternary158"
    reason: "FFN bulk layers are highly quantizable with QAT"
}

# Layer norm: GF16 (normalization stability)
override "layer_norm" {
    layer_type: "LayerNorm"
    precision: "GF16"
    reason: "Normalization requires stable scaling factors"
}

# ==============================================================================
# HARDWARE CONSTRAINTS
# ==============================================================================

constraint "dsp_budget_xc7a100t" {
    target: "XC7A100T-FGG676"
    total_dsp: 240
    max_utilization: 0.95
    available_dsp: 228  # 240 * 0.95
}

constraint "memory_budget_parameter_golf" {
    target_mb: 16.0
    max_compression_ratio: 4.0
}

constraint "lut_budget_xc7a100t" {
    target: "XC7A100T-FGG676"
    total_lut: 63400
    max_utilization: 0.80
    available_lut: 50720  # 63400 * 0.80
}

# ==============================================================================
# COST MODELS
# ==============================================================================

cost_model "gf16" {
    lut_per_param: 71
    dsp_per_param: 16
    ff_per_param: 266
    cells_per_param: 549
}

cost_model "ternary" {
    lut_per_param: 52
    dsp_per_param: 0
    ff_per_param: 69
    cells_per_param: 71
}

# ==============================================================================
# TRANSITION OPTIMIZATION
# ==============================================================================

# Minimize GF16 <-> Ternary transitions to avoid format hopping overhead
rule "minimize_transitions" {
    penalty: 0.5  # ~50% loss from format hopping
    strategy: "group_ternary_blocks"
    description: "Group consecutive ternary layers to minimize quantize/dequantize overhead"
}

# ==============================================================================
# VALIDATION RULES
# ==============================================================================

validate "critical_layers_gf16" {
    check: "layer.sensitivity == 'HIGH' implies layer.precision == 'GF16'"
    error: "CRITICAL: HIGH sensitivity layer '{layer.name}' must use GF16, got '{layer.precision}'"
}

validate "dsp_budget_not_exceeded" {
    check: "total_dsp_used <= dsp.available"
    error: "CRITICAL: DSP budget exceeded: {total_dsp_used}/{dsp.available}"
}

validate "memory_budget_not_exceeded" {
    check: "total_memory_mb <= 16.0"
    error: "CRITICAL: Memory budget exceeded: {total_memory_mb}MB > 16.0MB"
}

# ==============================================================================
# END OF POLICY
# ==============================================================================
