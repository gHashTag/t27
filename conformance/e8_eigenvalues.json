{
  "description": "E8/E9 Lie Algebra Conformance Vectors — KEPLER-NEWTON Direction A",
  "version": "1.0",
  "source_module": "math::e8_lie_algebra",
  "references": [
    "Aschheim, Minkowski Institute Press (2017)",
    "Dechant, Proc. Roy. Soc. A 472 (2016)",
    "Humphreys, Introduction to Lie Algebras"
  ],

  "constants": {
    "E8_RANK": {"value": 8, "critical": true},
    "E8_DIM": {"value": 248, "critical": true},
    "E8_NUM_ROOTS": {"value": 240, "critical": true},
    "E8_COXETER": {"value": 30, "critical": true}
  },

  "vectors": [
    {
      "name": "E9 Cartan Matrix Eigenvalues (Aschheim Theorem)",
      "description": "The 9x9 affine E8 Cartan matrix has exactly 4 phi-related eigenvalues",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "eigenvalues_sorted": [
              0.0,
              0.381966011250105,
              1.0,
              1.381966011250105,
              2.0,
              2.618033988749895,
              3.0,
              3.618033988749895,
              4.0
            ],
            "phi_related_count": 4,
            "phi_squared": 2.618033988749895,
            "phi_inv_squared": 0.381966011250105,
            "trinity_from_spectrum": 3.0
          },
          "tolerance": {
            "max_abs_error": 1.0e-12
          }
        }
      ]
    },
    {
      "name": "E9 Null Vector",
      "description": "A * delta = 0 where delta = [1,2,3,4,5,6,4,2,3]",
      "test_cases": [
        {
          "input": {
            "delta": [1, 2, 3, 4, 5, 6, 4, 2, 3]
          },
          "expected": {
            "product": [0, 0, 0, 0, 0, 0, 0, 0, 0],
            "delta_sum": 30
          }
        }
      ]
    },
    {
      "name": "E9 Characteristic Polynomial Factorization",
      "description": "P(x) = x(x-1)(x-2)(x-3)(x-4)(x^2-3x+1)(x^2-5x+5)",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "quadratic_1_coeffs": [1, -3, 1],
            "quadratic_1_discriminant": 5,
            "quadratic_1_roots": [2.618033988749895, 0.381966011250105],
            "quadratic_2_coeffs": [1, -5, 5],
            "quadratic_2_discriminant": 5,
            "quadratic_2_roots": [3.618033988749895, 1.381966011250105]
          },
          "note": "Both discriminants equal 5 via McKay correspondence (icosahedral group)"
        }
      ]
    },
    {
      "name": "E8 Marks (Highest Root Coefficients)",
      "description": "theta = 2a1 + 3a2 + 4a3 + 5a4 + 6a5 + 4a6 + 2a7 + 3a8",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "marks": [2, 3, 4, 5, 6, 4, 2, 3],
            "marks_sum": 29,
            "marks_product": 17280,
            "marks_set": [2, 3, 4, 5, 6]
          }
        }
      ]
    },
    {
      "name": "E8 Exponents",
      "description": "Degrees of basic polynomial invariants minus 1",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "exponents": [1, 7, 11, 13, 17, 19, 23, 29],
            "exponents_sum": 120,
            "h4_subset": [1, 11, 19, 29]
          },
          "note": "H4 exponents are a subset (shared Coxeter number h=30)"
        }
      ]
    },
    {
      "name": "Perron-Frobenius Eigenvector",
      "description": "PF eigenvector of 2I-C (adjacency) normalized to v[0]=1. Contains phi at index 6.",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "pf_vector": [1.0, 1.989044, 2.956295, 3.891157, 4.783386, 3.218340, 1.618034, 2.404867],
            "phi_index": 6,
            "phi_value": 1.618033988749895
          },
          "tolerance": {"max_abs_error": 1.0e-4}
        }
      ]
    }
  ]
}
