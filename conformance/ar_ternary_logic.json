      "expected": {"value": 1}
    },
    {
      "name": "no_tautology_or_not_unknown_k3_violation",
      "description": "No-tautology: OR(U, NOT(U)) = U != T (K3 violation of binary tautology)",
      "verdict": "CLEAN",
      "input": {"a": 0},
      "expected": {"value": 0}
    },
    {
      "name": "isomorphism_bijection_neg_to_false",
      "description": "Isomorphism: Trit.neg maps to K_FALSE",
