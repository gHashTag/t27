{
  "description": "Zamolodchikov E8 Mass Spectrum Conformance Vectors — KEPLER-NEWTON",
  "version": "1.0",
  "source_module": "math::zamolodchikov_e8",
  "references": [
    "Zamolodchikov, Int. J. Mod. Phys. A4 (1989) 4235",
    "Coldea et al., Science 327 (2010) 177",
    "Koca & Koca, arXiv:1204.4567 (2012)"
  ],

  "vectors": [
    {
      "name": "E8 Mass Spectrum (Exact Ratios)",
      "description": "8 particle masses from E8 affine Toda field theory, normalized to m1=1",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "m1": 1.0,
            "m2": 1.6180339887,
            "m3": 1.9890437907,
            "m4": 2.4048671724,
            "m5": 2.9562952015,
            "m6": 3.2183404585,
            "m7": 3.8911568233,
            "m8": 4.7833861168
          },
          "tolerance": {"max_abs_error": 1.0e-8}
        }
      ]
    },
    {
      "name": "Golden Ratio Mass Relations",
      "description": "Four pairs of masses differ by factor phi (exact, from H4 subgroup)",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "m2_over_m1": 1.6180339887498948,
            "m6_over_m3": 1.6180339887498948,
            "m7_over_m4": 1.6180339887498948,
            "m8_over_m5": 1.6180339887498948,
            "all_equal_phi": true
          },
          "tolerance": {"max_abs_error": 1.0e-10},
          "critical": true
        }
      ]
    },
    {
      "name": "Experimental Confirmation (Coldea 2010)",
      "description": "CoNb2O6 near quantum critical point: m2/m1 -> phi",
      "test_cases": [
        {
          "input": {
            "material": "CoNb2O6",
            "reference": "Science 327 (2010) 177"
          },
          "expected": {
            "observed_ratio": 1.618,
            "predicted_ratio": 1.6180339887,
            "agreement": "within experimental resolution"
          },
          "note": "First experimental observation of E8 symmetry in condensed matter"
        }
      ]
    },
    {
      "name": "Sacred Formula n-value E8 Mark Decomposition",
      "description": "n = E8_mark * 3^j hypothesis (2.7x enrichment over random)",
      "test_cases": [
        {"input": {"n": 6},   "expected": {"mark": 2, "power_of_3": 1, "is_mark": true}},
        {"input": {"n": 4},   "expected": {"mark": 4, "power_of_3": 0, "is_mark": true}},
        {"input": {"n": 2},   "expected": {"mark": 2, "power_of_3": 0, "is_mark": true}},
        {"input": {"n": 162}, "expected": {"mark": 2, "power_of_3": 4, "is_mark": true}},
        {"input": {"n": 135}, "expected": {"mark": 5, "power_of_3": 3, "is_mark": true}},
        {"input": {"n": 7},   "expected": {"mark": 7, "power_of_3": 0, "is_mark": false, "is_exponent": true}},
        {"input": {"n": 199}, "expected": {"is_mark": false, "is_exponent": false}}
      ]
    },
    {
      "name": "PF Eigenvector = Zamolodchikov Masses",
      "description": "Same 8 numbers in different Dynkin ordering",
      "test_cases": [
        {
          "input": {},
          "expected": {
            "pf_to_zam_mapping": [1, 3, 5, 7, 8, 6, 2, 4],
            "mapping_note": "PF[i] = m_{mapping[i]} for all i"
          }
        }
      ]
    }
  ]
}
