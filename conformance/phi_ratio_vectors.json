      "input": { "bits": 16 },
      "expected": {
        "exp_bits": 4,
        "mant_bits": 11,
        "phi_dist_less_than": 0.05
      }
    },
    {
      "name": "phi_split_gf32",
      "description": "GF32 phi-split: 31 available bits -> exp=8, mant=23",
