        "exp_bits": 1,
        "mant_bits": 2,
        "phi_dist_less_than": 0.01
      }
    },
    {
      "name": "phi_split_gf8",
      "description": "GF8 phi-split: 7 available bits -> exp=2, mant=5",
      "verdict": "CLEAN",
      "input": { "bits": 8 },
      "expected": {
        "exp_bits": 2,
        "mant_bits": 5,
        "phi_dist_less_than": 0.25
      }
    },
    {
      "name": "phi_split_gf12",
      "description": "GF12 phi-split: 11 available bits -> exp=3, mant=8",
      "verdict": "CLEAN",
      "input": { "bits": 12 },
      "expected": {
        "exp_bits": 3,
        "mant_bits": 8,
        "phi_dist_less_than": 0.25
      }
    },
    {
      "name": "phi_split_gf16",
      "description": "GF16 phi-split: 15 available bits -> exp=4, mant=11",
