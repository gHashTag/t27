    {
      "name": "phi_split_sum_constraint",
      "description": "exp_bits + mant_bits must equal bits - 1",
      "verdict": "CLEAN",
      "input": { "bits": 16 },
      "expected": {
        "sum_equals": 15
      }
    },
    {
      "name": "phi_distance_gf16_actual",
      "description": "GF16 actual format (6/9) has phi distance > 0.04",
