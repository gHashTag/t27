      "name": "trit_min_idempotent"
    },
    {
      "assertion": "for_all(a in {-1,0,1}): trit_max(a,a) == a",
      "description": "trit_max(a, a) == a for all a",
      "name": "trit_max_idempotent"
    },
    {
      "assertion": "for_all(a,b in {-1,0,1}): trit_min(a,b) == trit_max(b,a)",
      "description": "trit_min(a, b) == trit_max(b, a) for all a, b",
      "name": "trit_min_max_antisymmetric"
    },
    {
      "assertion": "for_all(x in {-1,1}): trit_power(x,0) == 1",
