      "description": "XOR-like ternary bind: if a==0 return b; if b==0 return a; else a*b",
      "cases": [
        {
          "id": "vsa_bind_with_zeros",
          "a": [0, 1, -1],
          "b": [1, 0, -1],
          "expected": [1, 1, 1]
