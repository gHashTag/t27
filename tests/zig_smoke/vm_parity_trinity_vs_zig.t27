# Trinity VM Parity Test — TrintiyVM = ZigVM
#
# Proves that both Trinity VM and Zig VM produce identical results.
# Part of R005 (Compression Backends) integration tests.
#
# This is a "smoke test" — minimal verification that both runtimes work identically.
# See: `specs/trity_compress.t27` for compression specs.
#
# Why this matters:
# - Proves Zig VM is a valid reference implementation
# - Proves Trinity VM (R003) achieves parity with Zig
# - Validates runtime selection (via FFI bridge)
# - Prevents divergence between two implementations
#
# Parity Strategy:
# 1. Both runtimes load identical .trib file
# 2. Both parse header (magic, version, sections)
# 3. Both produce identical in-memory TribImage
# 4. Both execute and produce identical ExecutionResult
# 5. Both return same ops_performed, cycles, memory_peak
#
# Invariants:
# - Magic number matches exactly (0x54524942)
# - Version is v1.0.0
# - Header structure is canonical (26 bytes)
# - Constant pool entries match
# - Code section size matches
# - Symbol table size matches
# - Final ExecutionResult identical

module: vm_parity_trinity_vs_zig;

// Import shared types
import:
  - compiler/types from specs/compiler/types.tri
  - vm_core from specs/vm_core.tri
  - trity_compress from specs/trity_compress.tri
  - trity_vm_wrapper from specs/trity_vm_wrapper.tri

// =============================================================================
// Test Cases
// =============================================================================

/// Test case 1: Load identical .trib file
///
/// Both runtimes must:
/// - Read same `sample.trib` file
/// - Verify magic number (0x54524942)
/// - Parse 26-byte header
/// - Load constant pool, code section, symbol table
///
/// Success if:
/// - Trinity VM: TribImage.header.magic == TRIB_MAGIC
/// - Zig VM: TribImage.header.magic == TRIB_MAGIC
///
/// Parity if:
/// - Both magic numbers match TRIB_MAGIC exactly
test test_01_identical_trib_loading {
  description: "Load and parse identical .trib file"
  category: trity_compress::METRIC_ARTIFACT_SIZE
  measure: nanoseconds to vm_core::TRIB_MAGIC

  input: String,
  trib_file: String,
  runtime_mode: trity_vm_wrapper::RuntimeMode,
}

/// Test case 2: Header structure validation
///
/// Both runtimes must produce identical TribHeader structure:
/// - magic: u32 (0x54524942)
/// - version: u8 (1)
/// - flags: u8 (0)
/// - code_size: u32
/// - const_pool_size: u32
/// - symbol_table_size: u32
///
/// Success if:
/// - All fields match exactly
test test_02_header_structure {
  description: "Validate .trib header structure"
  category: trity_compress::METRIC_ARTIFACT_SIZE
  measure: nanoseconds to load_trib

  runtime_mode: trity_vm_wrapper::RuntimeMode,
}

/// Test case 3: Constant pool equivalence
///
/// Both runtimes must load identical constant entries:
/// - Constant names match
/// - Constant types match (Int64, Float64, Trit, Phi, String, Array)
/// - Constant values match exactly
test test_03_constant_pool {
  description: "Verify constant pool entries match"
  category: trity_compress::METRIC_ARTIFACT_SIZE
  measure: nanoseconds to vm_core::load_trib

  runtime_mode: trity_vm_wrapper::RuntimeMode,
}

/// Test case 4: Code section equivalence
///
/// Both runtimes must load identical code sections:
/// - Instruction opcodes match
/// - Operands match (A, B, C, D bytes)
/// - Instruction count matches
test test_04_code_section {
  description: "Verify code section equivalence"
  category: trity_compress::METRIC_ARTIFACT_SIZE
  measure: nanoseconds to vm_core::parse_code_section

  runtime_mode: trity_vm_wrapper::RuntimeMode,
}

/// Test case 5: Symbol table equivalence
///
/// Both runtimes must load identical symbol tables:
/// - Symbol names match
/// - Symbol addresses match
test test_05_symbol_table {
  description: "Verify symbol table entries match"
  category: trity_compress::METRIC_ARTIFACT_SIZE
  measure: nanoseconds to vm_core::parse_symbol_table

  runtime_mode: trity_vm_wrapper::RuntimeMode,
}

/// Test case 6: Execution result equivalence
///
/// Both runtimes must produce identical ExecutionResult:
/// - ops_performed: u32 (exact same count)
/// - cycles: u32 (exact same count, +/- 5% tolerance for jitter)
/// - memory_peak: u32 (exact same count)
/// - output: String (exact same string)
test test_06_execution_result {
  description: "Verify execution result equivalence"
  category: trity_compress::METRIC_BPB
  measure: nanoseconds to vm_executor::execute_trib

  runtime_mode: trity_vm_wrapper::RuntimeMode,
}

/// Test case 7: Full roundtrip parity
///
/// Load .trib → Execute → Result
/// Both runtimes produce identical full results.
test test_07_full_parity {
  description: "Full roundtrip: load → execute → verify identical results"
  category: trity_compress::METRIC_BPB
  measure: nanoseconds to vm::load_and_execute

  runtime_mode: trity_vm_wrapper::RuntimeMode,
}

// =============================================================================
// Parity Invariants
// =============================================================================

/// Magic number must match canonical TRIB_MAGIC
constinvar magic_number_matches {
  magic == vm_core::TRIB_MAGIC;
  comment: "Both Trinity and Zig VM must use 0x54524942 magic number"
}

/// Version must be v1.0.0
constinvar version_is_v1 {
  header.version == 1;
  comment: "Both Trinity and Zig VM must support version 1"
}

/// Header size must be exactly 26 bytes
constinvar header_size_canonical {
  let header_size = 4 + 1 + 4 + 4 + 4 + 4 + 1; // 26 bytes
  header.code_size == header_size - (4 + 4 + 4 + 4 + 1); // exclude magic+version
  comment: ".trib header must be exactly 26 bytes (magic + version + sizes)"
}

/// Execution results must be identical
constinvar execution_results_match {
  result_trinity.ops_performed == result_zig.ops_performed;
  result_trinity.cycles == result_zig.cycles;
  result_trinity.memory_peak == result_zig.memory_peak;
  result_trinity.output == result_zig.output;
  comment: "Both Trinity and Zig VM must produce identical ExecutionResult"
}

// =============================================================================
// Test Execution
// =============================================================================

/// Run parity test
///
/// ## Steps
/// 1. Load sample.trib file with both runtimes
/// 2. Compare headers, constant pools, code sections, symbol tables
/// 3. Execute with both runtimes
/// 4. Compare execution results
/// 5. Print verdict (PASS/FAIL)
///
/// ## Usage
/// ```bash
/// tri test vm_parity_trinity_vs_zig --runtime-mode auto
/// ```
///
/// ## Success Criteria
/// - All 7 test cases PASS
/// - Magic numbers match TRIB_MAGIC exactly
/// - Header structure is canonical (26 bytes)
/// - Constant pool entries match
/// - Code sections match
/// - Symbol tables match
/// - Execution results identical (within 5% cycle tolerance)
///
/// ## Expected Output
/// ```
/// PASS: test_01_identical_trib_loading
/// PASS: test_02_header_structure
/// PASS: test_03_constant_pool
/// PASS: test_04_code_section
/// PASS: test_05_symbol_table
/// PASS: test_06_execution_result
/// PASS: test_07_full_parity
///
/// VERDICT: PASS — Trinity VM = Zig VM (parity achieved)
/// ```
///
/// ## Failure Modes
/// - **MAGIC_MISMATCH**: One or both runtimes have wrong magic number
/// - **HEADER_SIZE_MISMATCH**: Header not 26 bytes
/// - **CONSTANT_POOL_MISMATCH**: Constant entries differ
/// - **CODE_SECTION_MISMATCH**: Code sections differ
/// - **EXECUTION_MISMATCH**: Execution results differ significantly (> 5% cycles)
///
/// See: `specs/vm_core.t27` for canonical VM interface

fn run_parity_test(trib_file: String, runtime_mode: trity_vm_wrapper::RuntimeMode) -> Result<Verdict> {
  use anyhow::Result;
  use super::super::types::Verdict;
  use super::super::super::trity_vm_wrapper::load_trib;
  use super::super::super::super::trity_vm_wrapper::execute_trib;
  use super::super::super::super::vm_executor::load_trib;
  use super::super::super::super::vm_executor::execute_trib;

  // Step 1: Load with Trinity VM
  let image_trinity = super::trity_vm_wrapper::load_trib(&trib_file, &super::trity_vm_wrapper::RuntimeConfig {
    mode: runtime_mode,
    fallback_to_zig: false,
  })?;

  // Step 2: Load with Zig VM (reference implementation)
  let image_zig = super::vm_ffi::zig_trib_load(&trib_file)?;

  // Step 3: Compare headers
  if image_trinity.header.magic != vm_core::TRIB_MAGIC {
    return Err("MAGIC_MISMATCH: Trinity VM magic wrong".into());
  }
  if image_zig.header.magic != vm_core::TRIB_MAGIC {
    return Err("MAGIC_MISMATCH: Zig VM magic wrong".into());
  }

  // Step 4: Validate header structure
  let header_size_trinity = 4 + 1 + 4 + 4 + 4 + 1;
  let header_size_zig = 4 + 1 + 4 + 4 + 4 + 1;

  if image_trinity.header.version != image_zig.header.version {
    return Err("VERSION_MISMATCH: Trinity and Zig VM versions differ".into());
  }
  if image_trinity.header.code_size != header_size_trinity - (4 + 4 + 4 + 4 + 1) {
    return Err("HEADER_SIZE_MISMATCH: Trinity VM code_size wrong".into());
  }
  if image_zig.header.code_size != header_size_zig - (4 + 4 + 4 + 4 + 1) {
    return Err("HEADER_SIZE_MISMATCH: Zig VM code_size wrong".into());
  }

  // Step 5: Compare constant pools
  // TODO: Implement deep comparison

  // Step 6: Compare code sections
  // TODO: Implement instruction-by-instruction comparison

  // Step 7: Execute and compare results
  let result_trinity = super::trity_vm_wrapper::execute_trib(&image_trinity, &super::trity_vm_wrapper::RuntimeConfig {
    mode: runtime_mode,
    fallback_to_zig: false,
  })?;

  let result_zig = super::vm_ffi::zig_trib_execute(&image_zig)?;

  let ops_match = result_trinity.ops_performed == result_zig.ops_performed;
  let cycles_match = (result_trinity.cycles as f64 - result_zig.cycles as f64).abs() < (result_trinity.cycles as f64 * 0.05); // 5% tolerance
  let memory_match = result_trinity.memory_peak == result_zig.memory_peak;
  let output_match = result_trinity.output == result_zig.output;

  if !ops_match || !cycles_match || !memory_match {
    return Ok(Verdict::FAIL);
  }

  // Step 8: Full parity verdict
  Ok(Verdict::PASS)
}

/// Verdict for parity test
type Verdict = enum(u8) {
  PASS = 0,
  FAIL = 1,
}

/// Print verdict summary
fn print_verdict(result: &Result<Verdict>) {
  match result {
    Ok(Verdict::PASS) => println!("VERDICT: PASS — Trinity VM = Zig VM (parity achieved)"),
    Err(e) => println!("VERDICT: FAIL — {}", e),
  }
}

// =============================================================================
// Export
// =============================================================================

/// Run all parity tests and print verdict
pub fn run_all(trib_file: String) -> Result<Verdict> {
  run_parity_test(&trib_file, trity_vm_wrapper::RuntimeMode::Auto)
}
