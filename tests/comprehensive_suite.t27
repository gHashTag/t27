module tests-comprehensive-suite;

pub const SUITE_PHASE_COUNT : u8 = 6;

pub const PHASE_PARSE : u8 = 1;
pub const PHASE_GEN_ZIG : u8 = 2;
pub const PHASE_GEN_VERILOG : u8 = 3;
pub const PHASE_GEN_C : u8 = 4;
pub const PHASE_SEAL_VERIFY : u8 = 5;
pub const PHASE_FIXED_POINT : u8 = 6;

test "suite_has_six_phases" {
    try std.testing.expectEqual(@as(u8, 6), SUITE_PHASE_COUNT);
}
