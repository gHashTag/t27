# Query examples (jq):
# Find all toxic verdicts:      jq 'select(.verdict == "toxic")' decision-log.jsonl
# Find guardrail hits:          jq 'select(.guardrail_hit == true)' decision-log.jsonl
# Find replay events:           jq 'select(.event_type == "replay")' decision-log.jsonl
# Trace a specific task:          jq 'select(.task_id == "base-ops-extension")' decision-log.jsonl
# Get queen health trend:        jq '[.queen_health_after.queen]' decision-log.jsonl
