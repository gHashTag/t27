# Decision Log Schema
# Newline-delimited JSON (JSONL) for structured decision logging
# Each line is a complete JSON object for one decision/event

[
  {
    "trace_id": "uuid-v4",                    # Unique trace identifier for correlation
    "timestamp": "2026-04-04T12:34:56Z",   # ISO-8601 timestamp
    "task_id": "base-ops-extension",           # Current task context
    "skill_id": "ops_tritRotate_v1",          # Skill being executed
    "event_type": "mutation|recovery|replay|health_check|guardrail",
    "spec_path": "specs/base/ops.t27",        # Modified spec file
    "spec_hash_before": "a7f3c9d5e...",      # Spec hash before change
    "spec_hash_after": "b2e8a1f3c...",       # Spec hash after change
    "gen_hash_after": "c3d9b2e1a...",        # Generated backend hash
    "test_vector_hash": "d4e0c9b2a...",      # Test vectors hash
    "tool": "Edit|Read|Bash|tri_gen|tri_test|tri_verdict|tri_experience",
    "decision_summary": "Added tritRotate operation following PHI LOOP",
    "guardrail_hit": false,                   # Whether guardrail was triggered
    "policy_version": "1.0.0",              # Constitutional policy version
    "queen_health_before": {                     # Health snapshot before
      "spec": 1.0,
      "graph": 1.0,
      "bench": 1.0,
      "swarm": 0.95,
      "queen": 0.97
    },
    "queen_health_after": {                      # Health snapshot after
      "spec": 1.0,
      "graph": 1.0,
      "bench": 1.0,
      "swarm": 0.97,
      "queen": 0.99
    },
    "verdict": "clean|toxic",                # Verification verdict
    "bench_delta": "+0.2ns|+5%|null",  # Performance change
    "recovery_action": null,                     # Recovery action if any
    "sealed_at": "2026-04-04T12:34:56Z",    # When seal was created
    "duration_ms": 1234                       # Operation duration
  }
]

